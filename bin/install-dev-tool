#!/bin/bash

# setup-zsh Developer Tool Installer
# Installs and updates Bun, Go, JDK (Eclipse Temurin LTS), Node.js, Python & uv, Rust, Git, OrbStack, Android Studio, VSCode, DBeaver, MongoDB Compass, Antigravity, Claude, and Google Chrome on macOS.

# ANSI color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Detect architecture
ARCH=$(uname -m)
if [ "$ARCH" = "x86_64" ]; then
    GO_ARCH="amd64"
    NODE_ARCH="x64"
    ORB_ARCH="amd64"
    DBEAVER_ARCH="x86_64"
    JDK_ARCH="x64"
else
    GO_ARCH="arm64"
    NODE_ARCH="arm64"
    ORB_ARCH="arm64"
    DBEAVER_ARCH="aarch64"
    JDK_ARCH="aarch64"
fi

LOG_DIR="$HOME/.zsh/setup-zsh"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/install.log"

log_msg() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"
}
trap 'log_msg "Shell error on line $LINENO (command: $BASH_COMMAND)"' ERR

TEMP_VER_DIR=$(mktemp -d /tmp/setup-zsh-versions.XXXXXX)

# Launch parallel version checks in the background (Git is system-managed, so no check needed)
(
    LATEST=$(curl -s 'https://go.dev/VERSION?m=text' | head -n1 | sed 's/^go//' || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/go"
) &

(
    LATEST=$(curl -s https://nodejs.org/dist/index.tab | awk 'NR==2 {print $1}' | sed 's/^v//' || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/node"
) &

(
    LATEST=$(curl -s "https://cdn-updates.orbstack.dev/${ORB_ARCH}/appcast.new.xml" | grep -o '<sparkle:shortVersionString>[^<]*' | head -n 1 | sed 's/<sparkle:shortVersionString>//' || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/orb"
) &

(
    LATEST=$(curl -s "https://update.code.visualstudio.com/api/update/darwin-universal/stable/latest" | grep -o '"name":"[^"]*"' | head -n 1 | cut -d'"' -f4 || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/vscode"
) &

(
    LATEST=$(curl -s -L --compressed https://www.python.org/downloads/macos/ | grep -o 'https://www.python.org/ftp/python/[0-9.]*/python-[0-9.]*-macos11.pkg' | sort -V | tail -n 1 | cut -d/ -f6 || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/python"
) &

(
    LATEST=$(curl -s https://formulae.brew.sh/api/formula/uv.json | grep -o '"stable":"[^"]*"' | head -n 1 | cut -d'"' -f4 || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/uv"
) &

(
    LTS_VER=$(curl -s "https://api.adoptium.net/v3/info/available_releases" | grep -o '"most_recent_lts": [0-9]*' | tr -d ' ' | cut -d: -f2 || echo "21")
    LATEST=$(curl -s "https://api.adoptium.net/v3/assets/feature_releases/${LTS_VER}/ga?architecture=${JDK_ARCH}&image_type=jdk&os=mac&vendor=eclipse" | grep -o '"release_name": "[^"]*"' | head -n 1 | cut -d'"' -f4 | sed 's/^jdk-//' || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/jdk"
) &

(
    LATEST=$(curl -s https://downloads.claude.ai/releases/darwin/universal/RELEASES.json | grep -o '"currentRelease":"[^"]*"' | head -n 1 | cut -d'"' -f4 || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/claude"
) &

(
    LATEST=$(curl -s https://static.rust-lang.org/dist/channel-rust-stable.toml | grep -A 2 '\[pkg.rust\]' | grep 'version =' | cut -d'"' -f2 | cut -d' ' -f1 || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/rust"
) &

(
    LATEST=$(curl -s https://formulae.brew.sh/api/cask/mongodb-compass.json | grep -o '"version":"[^"]*"' | head -n 1 | cut -d'"' -f4 || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/compass"
) &

(
    LATEST=$(curl -s https://formulae.brew.sh/api/cask/dbeaver-community.json | grep -o '"version":"[^"]*"' | head -n 1 | cut -d'"' -f4 || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/dbeaver"
) &

(
    LATEST=$(curl -s https://formulae.brew.sh/api/cask/google-chrome.json | grep -o '"version":"[^"]*"' | head -n 1 | cut -d'"' -f4 || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/chrome"
) &

(
    LATEST=$(curl -s https://formulae.brew.sh/api/cask/android-studio.json | grep -o '"version":"[^"]*"' | head -n 1 | cut -d'"' -f4 | cut -d',' -f1 || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/android_studio"
) &

(
    LATEST=$(curl -s https://formulae.brew.sh/api/cask/codex-app.json | grep -o '"version":"[^"]*"' | head -n 1 | cut -d'"' -f4 || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/codex"
) &

(
    LATEST=$(curl -s https://formulae.brew.sh/api/cask/antigravity.json | grep -o '"version":"[^"]*"' | head -n 1 | cut -d'"' -f4 | cut -d',' -f1 || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/antigravity"
) &

(
    LATEST=$(curl -s https://formulae.brew.sh/api/formula/bun.json | grep -o '"stable":"[^"]*"' | head -n 1 | cut -d'"' -f4 || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/bun"
) &

# Spinner loading indicator
show_spinner() {
    local delay=0.1
    local spinstr='|/-\'
    echo -n -e " ${CYAN}Checking for the latest updates...${NC} "
    while [[ -n $(jobs -r 2>/dev/null) ]]; do
        local temp=${spinstr#?}
        printf "[%c]" "$spinstr"
        spinstr=$temp${spinstr%"$temp"}
        sleep $delay
        printf "\b\b\b"
    done
    printf "   \b\b\b\n"
}

# Wait for all background tasks to finish
show_spinner
wait

# Read latest versions
LATEST_BUN=$(cat "$TEMP_VER_DIR/bun" 2>/dev/null || echo "Unknown")
LATEST_GO=$(cat "$TEMP_VER_DIR/go" 2>/dev/null || echo "Unknown")
LATEST_NODE=$(cat "$TEMP_VER_DIR/node" 2>/dev/null || echo "Unknown")
LATEST_ORB=$(cat "$TEMP_VER_DIR/orb" 2>/dev/null || echo "Unknown")
LATEST_VSCODE=$(cat "$TEMP_VER_DIR/vscode" 2>/dev/null || echo "Unknown")
LATEST_PYTHON=$(cat "$TEMP_VER_DIR/python" 2>/dev/null || echo "Unknown")
LATEST_UV=$(cat "$TEMP_VER_DIR/uv" 2>/dev/null || echo "Unknown")
LATEST_JDK=$(cat "$TEMP_VER_DIR/jdk" 2>/dev/null || echo "Unknown")
LATEST_CLAUDE=$(cat "$TEMP_VER_DIR/claude" 2>/dev/null || echo "Unknown")
LATEST_RUST=$(cat "$TEMP_VER_DIR/rust" 2>/dev/null || echo "Unknown")
LATEST_COMPASS=$(cat "$TEMP_VER_DIR/compass" 2>/dev/null || echo "Unknown")
LATEST_DBEAVER=$(cat "$TEMP_VER_DIR/dbeaver" 2>/dev/null || echo "Unknown")
LATEST_CHROME=$(cat "$TEMP_VER_DIR/chrome" 2>/dev/null || echo "Unknown")
LATEST_ANDROID_STUDIO=$(cat "$TEMP_VER_DIR/android_studio" 2>/dev/null || echo "Unknown")
LATEST_CODEX=$(cat "$TEMP_VER_DIR/codex" 2>/dev/null || echo "Unknown")
LATEST_ANTIGRAVITY=$(cat "$TEMP_VER_DIR/antigravity" 2>/dev/null || echo "Unknown")
rm -rf "$TEMP_VER_DIR"

# Detection helper functions
detect_bun() {
    if [[ -x "$HOME/.bun/bin/bun" ]]; then
        "$HOME/.bun/bin/bun" --version 2>/dev/null | sed 's/^v//' || echo ""
    elif command -v bun &>/dev/null; then
        bun --version 2>/dev/null | sed 's/^v//' || echo ""
    fi
}
detect_go() {
    if [[ -x "$HOME/.local/go/bin/go" ]]; then
        echo "$("$HOME/.local/go/bin/go" version | awk '{print $3}' | sed 's/^go//')"
    fi
}

detect_node() {
    if [[ -x "$HOME/.local/node/bin/node" ]]; then
        echo "$("$HOME/.local/node/bin/node" -v | sed 's/^v//')"
    fi
}

detect_orb() {
    if [[ -d "/Applications/OrbStack.app" ]]; then
        defaults read "/Applications/OrbStack.app/Contents/Info.plist" CFBundleShortVersionString 2>/dev/null || echo ""
    fi
}

detect_vscode() {
    if [[ -d "/Applications/Visual Studio Code.app" ]]; then
        defaults read "/Applications/Visual Studio Code.app/Contents/Info.plist" CFBundleShortVersionString 2>/dev/null || echo ""
    fi
}

detect_python() {
    if command -v python3 &>/dev/null; then
        python3 --version 2>&1 | awk '{print $2}' || echo ""
    fi
}

detect_uv() {
    if [[ -x "$HOME/.local/bin/uv" ]]; then
        "$HOME/.local/bin/uv" --version 2>/dev/null | awk '{print $2}' || echo ""
    elif command -v uv &>/dev/null; then
        uv --version 2>/dev/null | awk '{print $2}' || echo ""
    fi
}

detect_jdk() {
    if command -v java &>/dev/null; then
        java -version 2>&1 | awk -F '"' '/version/ {print $2}' || echo ""
    fi
}

detect_claude() {
    if [[ -d "/Applications/Claude.app" ]]; then
        defaults read "/Applications/Claude.app/Contents/Info.plist" CFBundleShortVersionString 2>/dev/null || echo ""
    fi
}

detect_rust() {
    if [[ -x "$HOME/.cargo/bin/rustc" ]]; then
        "$HOME/.cargo/bin/rustc" --version | awk '{print $2}' || echo ""
    fi
}

detect_git() {
    if command -v git &>/dev/null && xcode-select -p &>/dev/null; then
        git --version 2>/dev/null | awk '{print $3}' || echo ""
    fi
}

detect_compass() {
    if [[ -d "/Applications/MongoDB Compass.app" ]]; then
        defaults read "/Applications/MongoDB Compass.app/Contents/Info.plist" CFBundleShortVersionString 2>/dev/null || echo ""
    fi
}

detect_dbeaver() {
    if [[ -d "/Applications/DBeaver.app" ]]; then
        defaults read "/Applications/DBeaver.app/Contents/Info.plist" CFBundleShortVersionString 2>/dev/null || echo ""
    fi
}

detect_chrome() {
    if [[ -d "/Applications/Google Chrome.app" ]]; then
        defaults read "/Applications/Google Chrome.app/Contents/Info.plist" CFBundleShortVersionString 2>/dev/null || echo ""
    fi
}

detect_android_studio() {
    if [[ -d "/Applications/Android Studio.app" ]]; then
        defaults read "/Applications/Android Studio.app/Contents/Info.plist" CFBundleShortVersionString 2>/dev/null || echo ""
    fi
}

detect_codex() {
    if [[ -d "/Applications/Codex.app" ]]; then
        defaults read "/Applications/Codex.app/Contents/Info.plist" CFBundleShortVersionString 2>/dev/null || echo ""
    fi
}

detect_antigravity() {
    if [[ -d "/Applications/Antigravity.app" ]]; then
        defaults read "/Applications/Antigravity.app/Contents/Info.plist" CFBundleShortVersionString 2>/dev/null || echo ""
    fi
}

format_status() {
    local installed="$1"
    local latest="$2"
    if [[ -z "$installed" ]]; then
        echo -e "${RED}[Not Installed]${NC}"
    elif [[ "$installed" == "$latest" ]]; then
        echo -e "${GREEN}[Installed: v$installed (Latest)]${NC}"
    else
        echo -e "${YELLOW}[Installed: v$installed -> Upgrade to v$latest]${NC}"
    fi
}

format_python_status() {
    local py_inst="$1"
    local uv_inst="$2"
    if [[ -z "$py_inst" && -z "$uv_inst" ]]; then
        echo -e "${RED}[Not Installed]${NC}"
    elif [[ -n "$py_inst" && -n "$uv_inst" ]]; then
        echo -e "${GREEN}[Installed: Py v$py_inst | uv v$uv_inst]${NC}"
    elif [[ -n "$py_inst" ]]; then
        echo -e "${YELLOW}[Installed: Py v$py_inst | uv missing]${NC}"
    else
        echo -e "${YELLOW}[Installed: uv v$uv_inst | Python3 missing]${NC}"
    fi
}

format_git_status() {
    local installed="$1"
    if [[ -z "$installed" ]]; then
        echo -e "${RED}[Not Installed]${NC}"
    else
        echo -e "${GREEN}[Installed: v$installed (System Managed)]${NC}"
    fi
}

show_checkbox() {
    local val="$1"
    if [ "$val" -eq 1 ]; then
        echo -e "[${GREEN}✓${NC}]"
    else
        echo -e "[ ]"
    fi
}

show_line() {
    local line_num="$1"
    local content="$2"
    if [ "$CURSOR" -eq "$line_num" ]; then
        local hl_content
        hl_content=$(echo -e "$content" | sed "s/\x1b\[0m/\x1b\[0m\x1b\[1;36m/g")
        echo -e "${CYAN}❯ \033[1;36m${hl_content}${NC}\033[K"
    else
        echo -e "  $content\033[K"
    fi
}

show_action_item() {
    local line_num="$1"
    local text="$2"
    if [ "$CURSOR" -eq "$line_num" ]; then
        echo -n -e "${CYAN}❯ \033[1;36m${text}${NC}"
    else
        echo -n -e "  ${text}"
    fi
}

update_env_block() {
    local marker="$1"
    local content="$2"
    local env_file="$HOME/.zsh/setup-zsh/env.zsh"
    
    mkdir -p "$(dirname "$env_file")"
    touch "$env_file"
    
    local temp_file
    temp_file=$(mktemp /tmp/env_zsh.XXXXXX)
    awk -v start="# >>> ${marker} >>>" -v end="# <<< ${marker} <<<" '
        $0 == start {p=1; next}
        $0 == end {p=0; next}
        !p
    ' "$env_file" > "$temp_file"
    
    if [[ -n "$content" ]]; then
        echo -e "# >>> ${marker} >>>\n${content}\n# <<< ${marker} <<<" >> "$temp_file"
    fi
    
    mv "$temp_file" "$env_file"
}

confirm_reinstall() {
    local name="$1"
    local version="$2"
    echo -n -e "${YELLOW}${name} is already up-to-date (v${version}). Re-install? (y/N): ${NC}"
    read -r response
    if [[ "$response" =~ ^[Yy]$ ]]; then
        return 0
    else
        return 1
    fi
}

is_app_running() {
    local app_path="$1"
    if [[ -d "$app_path" ]]; then
        pgrep -f "$app_path" &>/dev/null
        return $?
    fi
    return 1
}

kill_app() {
    local app_path="$1"
    if pgrep -f "$app_path" &>/dev/null; then
        pkill -f "$app_path" 2>/dev/null || true
        sleep 1
        if pgrep -f "$app_path" &>/dev/null; then
            pkill -9 -f "$app_path" 2>/dev/null || true
        fi
    fi
}

reopen_app_if_was_running() {
    local app_name="$1"
    local app_path="$2"
    local was_running="$3"
    if [[ "$was_running" -eq 1 && -d "$app_path" ]]; then
        echo -e "${BLUE}Reopening ${app_name}...${NC}"
        open "$app_path" 2>/dev/null || true
    fi
}

install_bun() {
    echo -e "${BLUE}Installing Bun v${LATEST_BUN}...${NC}"
    if ! curl -fsSL https://bun.sh/install | bash; then
        echo -e "${RED}Error: Failed to install Bun.${NC}"
        return 1
    fi
    
    echo "Updating env.zsh..."
    local content="export BUN_INSTALL=\"\$HOME/.bun\"\nexport PATH=\"\$BUN_INSTALL/bin:\$PATH\""
    update_env_block "Bun" "$content"
    
    echo -e "${GREEN}✓ Bun v${LATEST_BUN} installed successfully!${NC}"
}

install_go() {
    echo -e "${BLUE}Installing Go v${LATEST_GO}...${NC}"
    local download_url="https://dl.google.com/go/go${LATEST_GO}.darwin-${GO_ARCH}.tar.gz"
    local temp_tar=$(mktemp /tmp/go.XXXXXX.tar.gz)
    
    echo "Downloading ${download_url}..."
    if ! curl -L --progress-bar "$download_url" -o "$temp_tar"; then
        echo -e "${RED}Error: Failed to download Go.${NC}"
        return 1
    fi
    
    echo "Extracting to ~/.local/go..."
    mkdir -p "$HOME/.local"
    rm -rf "$HOME/.local/go"
    if ! tar -xzf "$temp_tar" -C "$HOME/.local"; then
        echo -e "${RED}Error: Failed to extract Go.${NC}"
        rm -f "$temp_tar"
        return 1
    fi
    
    rm -f "$temp_tar"
    
    echo "Updating env.zsh..."
    local content="export GOROOT=\"\$HOME/.local/go\"\nexport GOPATH=\"\$HOME/go\"\nexport PATH=\"\$GOROOT/bin:\$GOPATH/bin:\$PATH\""
    update_env_block "Go" "$content"
    
    echo -e "${GREEN}✓ Go v${LATEST_GO} installed successfully!${NC}"
}

install_node() {
    local version="$1"
    echo -e "${BLUE}Installing Node.js v${version}...${NC}"
    local download_url="https://nodejs.org/dist/v${version}/node-v${version}-darwin-${NODE_ARCH}.tar.gz"
    local temp_tar=$(mktemp /tmp/node.XXXXXX.tar.gz)
    
    echo "Downloading ${download_url}..."
    if ! curl -L --progress-bar "$download_url" -o "$temp_tar"; then
        echo -e "${RED}Error: Failed to download Node.js.${NC}"
        return 1
    fi
    
    echo "Extracting to ~/.local/node..."
    mkdir -p "$HOME/.local"
    rm -rf "$HOME/.local/node"
    local temp_extract_dir
    temp_extract_dir=$(mktemp -d /tmp/node_extract.XXXXXX)
    if ! tar -xzf "$temp_tar" -C "$temp_extract_dir"; then
        echo -e "${RED}Error: Failed to extract Node.js.${NC}"
        rm -f "$temp_tar"
        rm -rf "$temp_extract_dir"
        return 1
    fi
    
    mv "$temp_extract_dir"/node-v${version}-darwin-${NODE_ARCH} "$HOME/.local/node"
    
    rm -f "$temp_tar"
    rm -rf "$temp_extract_dir"
    
    echo "Updating env.zsh..."
    local content="export PATH=\"\$HOME/.local/node/bin:\$PATH\""
    update_env_block "Node" "$content"
    
    echo -e "${GREEN}✓ Node.js v${version} installed successfully!${NC}"
    echo -e "${YELLOW}Note: Global npm packages will be installed under ~/.local/node without requiring sudo!${NC}"
}

install_orb() {
    echo -e "${BLUE}Installing OrbStack v${LATEST_ORB}...${NC}"
    local download_url
    download_url=$(curl -s "https://cdn-updates.orbstack.dev/${ORB_ARCH}/appcast.new.xml" | grep -o 'enclosure url="[^"]*"' | head -n 1 | cut -d'"' -f2 || echo "")
    if [[ -z "$download_url" ]]; then
        echo -e "${RED}Error: Failed to resolve OrbStack download URL.${NC}"
        return 1
    fi
    
    local temp_dmg=$(mktemp /tmp/orbstack.XXXXXX.dmg)
    
    echo "Downloading ${download_url}..."
    if ! curl -L --progress-bar "$download_url" -o "$temp_dmg"; then
        echo -e "${RED}Error: Failed to download OrbStack.${NC}"
        return 1
    fi
    
    echo "Mounting DMG..."
    local mount_point="/Volumes/OrbStack_temp_$$"
    mkdir -p "$mount_point"
    if ! hdiutil attach -nobrowse -readonly -mountpoint "$mount_point" "$temp_dmg"; then
        echo -e "${RED}Error: Failed to mount OrbStack DMG.${NC}"
        rm -f "$temp_dmg"
        rm -rf "$mount_point"
        return 1
    fi
    
    echo "Copying to Applications..."
    rm -rf "/Applications/OrbStack.app"
    if ! cp -R "${mount_point}/OrbStack.app" "/Applications/"; then
        echo -e "${RED}Error: Failed to copy OrbStack to /Applications.${NC}"
        hdiutil detach "$mount_point"
        rm -f "$temp_dmg"
        rm -rf "$mount_point"
        return 1
    fi
    
    echo "Unmounting DMG..."
    hdiutil detach "$mount_point"
    rm -rf "$mount_point"
    rm -f "$temp_dmg"
    
    echo "Updating env.zsh..."
    local content="if [[ -d \"/Applications/OrbStack.app/Contents/MacOS/bin\" ]]; then\n  export PATH=\"/Applications/OrbStack.app/Contents/MacOS/bin:\$PATH\"\nfi"
    update_env_block "OrbStack" "$content"
    
    echo -e "${GREEN}✓ OrbStack v${LATEST_ORB} installed to /Applications/OrbStack.app!${NC}"
    if [[ "$WAS_RUNNING_ORB" -eq 1 ]]; then
        reopen_app_if_was_running "OrbStack" "/Applications/OrbStack.app" "$WAS_RUNNING_ORB"
    else
        echo -e "${YELLOW}Please launch OrbStack to complete system setup: open -a OrbStack${NC}"
    fi
}

install_vscode() {
    echo -e "${BLUE}Installing VSCode v${LATEST_VSCODE}...${NC}"
    local download_url="https://update.code.visualstudio.com/latest/darwin-universal/stable"
    local temp_zip=$(mktemp /tmp/vscode.XXXXXX.zip)
    
    echo "Downloading ${download_url}..."
    if ! curl -L --progress-bar "$download_url" -o "$temp_zip"; then
        echo -e "${RED}Error: Failed to download VSCode.${NC}"
        return 1
    fi
    
    echo "Extracting..."
    local temp_extract_dir
    temp_extract_dir=$(mktemp -d /tmp/vscode_extract.XXXXXX)
    if ! unzip -q "$temp_zip" -d "$temp_extract_dir"; then
        echo -e "${RED}Error: Failed to extract VSCode.${NC}"
        rm -f "$temp_zip"
        rm -rf "$temp_extract_dir"
        return 1
    fi
    
    echo "Moving to Applications..."
    rm -rf "/Applications/Visual Studio Code.app"
    if ! cp -R "$temp_extract_dir/Visual Studio Code.app" "/Applications/"; then
        echo -e "${RED}Error: Failed to copy VSCode to /Applications.${NC}"
        rm -f "$temp_zip"
        rm -rf "$temp_extract_dir"
        return 1
    fi
    
    rm -f "$temp_zip"
    rm -rf "$temp_extract_dir"
    
    echo "Updating env.zsh..."
    local content="export PATH=\"/Applications/Visual Studio Code.app/Contents/Resources/app/bin:\$PATH\""
    update_env_block "VSCode" "$content"
    
    echo -e "${GREEN}✓ VSCode v${LATEST_VSCODE} installed to /Applications/Visual Studio Code.app!${NC}"
    reopen_app_if_was_running "VSCode" "/Applications/Visual Studio Code.app" "$WAS_RUNNING_VSCODE"
}

install_python() {
    echo -e "${BLUE}Installing Python v${LATEST_PYTHON}...${NC}"
    local download_url="https://www.python.org/ftp/python/${LATEST_PYTHON}/python-${LATEST_PYTHON}-macos11.pkg"
    local temp_pkg=$(mktemp /tmp/python.XXXXXX.pkg)
    
    echo "Downloading ${download_url}..."
    if ! curl -L --progress-bar "$download_url" -o "$temp_pkg"; then
        echo -e "${RED}Error: Failed to download Python.${NC}"
        return 1
    fi
    
    echo -e "${YELLOW}This installation requires administrator privileges. Please enter your password when prompted.${NC}"
    if ! sudo installer -pkg "$temp_pkg" -target /; then
        echo -e "${RED}Error: Failed to install Python pkg.${NC}"
        rm -f "$temp_pkg"
        return 1
    fi
    
    rm -f "$temp_pkg"
    
    echo -e "${BLUE}Installing uv (Python package installer v${LATEST_UV})...${NC}"
    mkdir -p "$HOME/.local/bin"
    if ! curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR="$HOME/.local/bin" sh; then
        echo -e "${YELLOW}Warning: Failed to install uv via installer script, attempting fallback...${NC}"
        local uv_arch="aarch64"
        if [ "$ARCH" = "x86_64" ]; then
            uv_arch="x86_64"
        fi
        local uv_url="https://github.com/astral-sh/uv/releases/download/${LATEST_UV}/uv-${uv_arch}-apple-darwin.tar.gz"
        local temp_uv_tar=$(mktemp /tmp/uv.XXXXXX.tar.gz)
        if curl -L --progress-bar "$uv_url" -o "$temp_uv_tar"; then
            local temp_uv_extract=$(mktemp -d /tmp/uv_extract.XXXXXX)
            tar -xzf "$temp_uv_tar" -C "$temp_uv_extract"
            mv "$temp_uv_extract"/uv-${uv_arch}-apple-darwin/uv* "$HOME/.local/bin/" 2>/dev/null || true
            rm -rf "$temp_uv_tar" "$temp_uv_extract"
        fi
    fi
    
    echo "Updating env.zsh..."
    local content="export PATH=\"\$HOME/.local/bin:\$PATH\"\nalias python=\"python3\"\nalias pip=\"pip3\""
    update_env_block "Python" "$content"
    
    echo -e "${GREEN}✓ Python v${LATEST_PYTHON} and uv v${LATEST_UV} installed successfully!${NC}"
}

install_jdk() {
    echo -e "${BLUE}Installing Eclipse Temurin JDK LTS v${LATEST_JDK}...${NC}"
    local lts_ver
    lts_ver=$(echo "$LATEST_JDK" | cut -d. -f1)
    [[ -z "$lts_ver" ]] && lts_ver="21"
    local download_url
    download_url=$(curl -s "https://api.adoptium.net/v3/assets/feature_releases/${lts_ver}/ga?architecture=${JDK_ARCH}&image_type=jdk&os=mac&vendor=eclipse" | grep -o 'https://github.com/adoptium/temurin[0-9]*-binaries/releases/download/[^"]*\.pkg' | head -n 1 || echo "")
    if [[ -z "$download_url" ]]; then
        echo -e "${RED}Error: Failed to resolve Temurin JDK download URL.${NC}"
        return 1
    fi
    local temp_pkg=$(mktemp /tmp/jdk.XXXXXX.pkg)
    
    echo "Downloading ${download_url}..."
    if ! curl -L --progress-bar "$download_url" -o "$temp_pkg"; then
        echo -e "${RED}Error: Failed to download Temurin JDK.${NC}"
        return 1
    fi
    
    echo -e "${YELLOW}This installation requires administrator privileges. Please enter your password when prompted.${NC}"
    if ! sudo installer -pkg "$temp_pkg" -target /; then
        echo -e "${RED}Error: Failed to install Temurin JDK pkg.${NC}"
        rm -f "$temp_pkg"
        return 1
    fi
    
    rm -f "$temp_pkg"
    
    echo "Updating env.zsh..."
    local content="if command -v /usr/libexec/java_home &>/dev/null; then\n  export JAVA_HOME=\"\$(/usr/libexec/java_home 2>/dev/null)\"\n  export PATH=\"\$JAVA_HOME/bin:\$PATH\"\nfi"
    update_env_block "JDK" "$content"
    
    echo -e "${GREEN}✓ Eclipse Temurin JDK LTS v${LATEST_JDK} installed successfully!${NC}"
}

install_claude() {
    echo -e "${BLUE}Installing Claude v${LATEST_CLAUDE}...${NC}"
    local download_url
    download_url=$(curl -s https://downloads.claude.ai/releases/darwin/universal/RELEASES.json | grep -o 'https://downloads.claude.ai/releases/darwin/universal/[^"]*' | head -n 1 || echo "")
    if [[ -z "$download_url" ]]; then
        echo -e "${RED}Error: Failed to resolve Claude download URL.${NC}"
        return 1
    fi
    
    local temp_zip=$(mktemp /tmp/claude.XXXXXX.zip)
    
    echo "Downloading ${download_url}..."
    if ! curl -L --progress-bar "$download_url" -o "$temp_zip"; then
        echo -e "${RED}Error: Failed to download Claude.${NC}"
        return 1
    fi
    
    echo "Extracting..."
    local temp_extract_dir
    temp_extract_dir=$(mktemp -d /tmp/claude_extract.XXXXXX)
    if ! unzip -q "$temp_zip" -d "$temp_extract_dir"; then
        echo -e "${RED}Error: Failed to extract Claude.${NC}"
        rm -f "$temp_zip"
        rm -rf "$temp_extract_dir"
        return 1
    fi
    
    echo "Moving to Applications..."
    rm -rf "/Applications/Claude.app"
    if ! cp -R "$temp_extract_dir/Claude.app" "/Applications/"; then
        echo -e "${RED}Error: Failed to copy Claude to /Applications.${NC}"
        rm -f "$temp_zip"
        rm -rf "$temp_extract_dir"
        return 1
    fi
    
    rm -f "$temp_zip"
    rm -rf "$temp_extract_dir"
    
    echo -e "${GREEN}✓ Claude v${LATEST_CLAUDE} installed to /Applications/Claude.app!${NC}"
    reopen_app_if_was_running "Claude" "/Applications/Claude.app" "$WAS_RUNNING_CLAUDE"
}

install_rust() {
    echo -e "${BLUE}Installing/Upgrading Rust v${LATEST_RUST}...${NC}"
    
    if [[ -x "$HOME/.cargo/bin/rustup" ]]; then
        echo "Updating Rust via rustup..."
        if ! "$HOME/.cargo/bin/rustup" update; then
            echo -e "${RED}Error: Failed to update Rust.${NC}"
            return 1
        fi
    else
        echo "Running official rustup installer..."
        if ! curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --no-modify-path; then
            echo -e "${RED}Error: Failed to install Rust via rustup.${NC}"
            return 1
        fi
    fi
    
    echo "Updating env.zsh..."
    local content="export PATH=\"\$HOME/.cargo/bin:\$PATH\""
    update_env_block "Rust" "$content"
    
    echo -e "${GREEN}✓ Rust v${LATEST_RUST} installed successfully!${NC}"
}

install_git() {
    echo -e "${BLUE}Installing Git via Xcode Command Line Tools...${NC}"
    if xcode-select -p &>/dev/null; then
        echo -e "${GREEN}✓ Xcode Command Line Tools are already installed.${NC}"
        echo -e "${YELLOW}Note: Git on macOS is managed by Xcode Command Line Tools.${NC}"
    else
        echo "Triggering Apple Xcode Command Line Tools installer..."
        xcode-select --install
        echo -e "${YELLOW}Please follow the instructions in the macOS pop-up window to complete the installation.${NC}"
        echo "Once installed, restart your terminal or run this script again."
    fi
}

install_compass() {
    echo -e "${BLUE}Installing MongoDB Compass v${LATEST_COMPASS}...${NC}"
    local download_url="https://downloads.mongodb.com/compass/mongodb-compass-${LATEST_COMPASS}-darwin-${NODE_ARCH}.dmg"
    local temp_dmg=$(mktemp /tmp/mongodb-compass.XXXXXX.dmg)
    
    echo "Downloading ${download_url}..."
    if ! curl -L --progress-bar "$download_url" -o "$temp_dmg"; then
        echo -e "${RED}Error: Failed to download MongoDB Compass.${NC}"
        return 1
    fi
    
    echo "Mounting DMG..."
    local mount_point="/Volumes/Compass_temp_$$"
    mkdir -p "$mount_point"
    if ! hdiutil attach -nobrowse -readonly -mountpoint "$mount_point" "$temp_dmg"; then
        echo -e "${RED}Error: Failed to mount MongoDB Compass DMG.${NC}"
        rm -f "$temp_dmg"
        rm -rf "$mount_point"
        return 1
    fi
    
    echo "Copying to Applications..."
    rm -rf "/Applications/MongoDB Compass.app"
    if ! cp -R "${mount_point}/MongoDB Compass.app" "/Applications/"; then
        echo -e "${RED}Error: Failed to copy MongoDB Compass to /Applications.${NC}"
        hdiutil detach "$mount_point"
        rm -f "$temp_dmg"
        rm -rf "$mount_point"
        return 1
    fi
    
    echo "Unmounting DMG..."
    hdiutil detach "$mount_point"
    rm -rf "$mount_point"
    rm -f "$temp_dmg"
    
    echo -e "${GREEN}✓ MongoDB Compass v${LATEST_COMPASS} installed to /Applications/MongoDB Compass.app!${NC}"
    reopen_app_if_was_running "MongoDB Compass" "/Applications/MongoDB Compass.app" "$WAS_RUNNING_COMPASS"
}

