#!/bin/bash

# setup-zsh Developer Tool Installer
# Installs and updates Go, Node.js, Python, Rust, Codex, Git, OrbStack, Android Studio, VSCode, DBeaver, MongoDB Compass, Antigravity, Claude, and Google Chrome on macOS.

# ANSI color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Detect architecture
ARCH=$(uname -m)
if [ "$ARCH" = "x86_64" ]; then
    GO_ARCH="amd64"
    NODE_ARCH="x64"
    ORB_ARCH="amd64"
    DBEAVER_ARCH="x86_64"
else
    GO_ARCH="arm64"
    NODE_ARCH="arm64"
    ORB_ARCH="arm64"
    DBEAVER_ARCH="aarch64"
fi

TEMP_VER_DIR=$(mktemp -d /tmp/setup-zsh-versions.XXXXXX)

# Launch parallel version checks in the background (Git is system-managed, so no check needed)
(
    LATEST=$(curl -s 'https://go.dev/VERSION?m=text' | head -n1 | sed 's/^go//' || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/go"
) &

(
    LATEST=$(curl -s https://nodejs.org/dist/index.tab | awk 'NR==2 {print $1}' | sed 's/^v//' || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/node"
) &

(
    LATEST=$(curl -s "https://cdn-updates.orbstack.dev/${ORB_ARCH}/appcast.new.xml" | grep -o '<sparkle:shortVersionString>[^<]*' | head -n 1 | sed 's/<sparkle:shortVersionString>//' || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/orb"
) &

(
    LATEST=$(curl -s "https://update.code.visualstudio.com/api/update/darwin-universal/stable/latest" | grep -o '"name":"[^"]*"' | head -n 1 | cut -d'"' -f4 || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/vscode"
) &

(
    LATEST=$(curl -s -L --compressed https://www.python.org/downloads/macos/ | grep -o 'https://www.python.org/ftp/python/[0-9.]*/python-[0-9.]*-macos11.pkg' | sort -V | tail -n 1 | cut -d/ -f6 || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/python"
) &

(
    LATEST=$(curl -s https://downloads.claude.ai/releases/darwin/universal/RELEASES.json | grep -o '"currentRelease":"[^"]*"' | head -n 1 | cut -d'"' -f4 || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/claude"
) &

(
    LATEST=$(curl -s https://static.rust-lang.org/dist/channel-rust-stable.toml | grep -A 2 '\[pkg.rust\]' | grep 'version =' | cut -d'"' -f2 | cut -d' ' -f1 || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/rust"
) &

(
    LATEST=$(curl -s https://formulae.brew.sh/api/cask/mongodb-compass.json | grep -o '"version":"[^"]*"' | head -n 1 | cut -d'"' -f4 || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/compass"
) &

(
    LATEST=$(curl -s https://formulae.brew.sh/api/cask/dbeaver-community.json | grep -o '"version":"[^"]*"' | head -n 1 | cut -d'"' -f4 || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/dbeaver"
) &

(
    LATEST=$(curl -s https://formulae.brew.sh/api/cask/google-chrome.json | grep -o '"version":"[^"]*"' | head -n 1 | cut -d'"' -f4 || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/chrome"
) &

(
    LATEST=$(curl -s https://formulae.brew.sh/api/cask/android-studio.json | grep -o '"version":"[^"]*"' | head -n 1 | cut -d'"' -f4 | cut -d',' -f1 || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/android_studio"
) &

(
    LATEST=$(curl -s https://formulae.brew.sh/api/cask/codex-app.json | grep -o '"version":"[^"]*"' | head -n 1 | cut -d'"' -f4 || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/codex"
) &

(
    LATEST=$(curl -s https://formulae.brew.sh/api/cask/antigravity.json | grep -o '"version":"[^"]*"' | head -n 1 | cut -d'"' -f4 | cut -d',' -f1 || echo "Unknown")
    echo "$LATEST" > "$TEMP_VER_DIR/antigravity"
) &

# Spinner loading indicator
show_spinner() {
    local delay=0.1
    local spinstr='|/-\'
    echo -n -e " ${CYAN}Checking for the latest updates...${NC} "
    while [[ -n $(jobs -r 2>/dev/null) ]]; do
        local temp=${spinstr#?}
        printf "[%c]" "$spinstr"
        spinstr=$temp${spinstr%"$temp"}
        sleep $delay
        printf "\b\b\b"
    done
    printf "   \b\b\b\n"
}

# Wait for all background tasks to finish
show_spinner
wait

# Read latest versions
LATEST_GO=$(cat "$TEMP_VER_DIR/go" 2>/dev/null || echo "Unknown")
LATEST_NODE=$(cat "$TEMP_VER_DIR/node" 2>/dev/null || echo "Unknown")
LATEST_ORB=$(cat "$TEMP_VER_DIR/orb" 2>/dev/null || echo "Unknown")
LATEST_VSCODE=$(cat "$TEMP_VER_DIR/vscode" 2>/dev/null || echo "Unknown")
LATEST_PYTHON=$(cat "$TEMP_VER_DIR/python" 2>/dev/null || echo "Unknown")
LATEST_CLAUDE=$(cat "$TEMP_VER_DIR/claude" 2>/dev/null || echo "Unknown")
LATEST_RUST=$(cat "$TEMP_VER_DIR/rust" 2>/dev/null || echo "Unknown")
LATEST_COMPASS=$(cat "$TEMP_VER_DIR/compass" 2>/dev/null || echo "Unknown")
LATEST_DBEAVER=$(cat "$TEMP_VER_DIR/dbeaver" 2>/dev/null || echo "Unknown")
LATEST_CHROME=$(cat "$TEMP_VER_DIR/chrome" 2>/dev/null || echo "Unknown")
LATEST_ANDROID_STUDIO=$(cat "$TEMP_VER_DIR/android_studio" 2>/dev/null || echo "Unknown")
LATEST_CODEX=$(cat "$TEMP_VER_DIR/codex" 2>/dev/null || echo "Unknown")
LATEST_ANTIGRAVITY=$(cat "$TEMP_VER_DIR/antigravity" 2>/dev/null || echo "Unknown")
rm -rf "$TEMP_VER_DIR"

# Detection helper functions
detect_go() {
    if [[ -x "$HOME/.local/go/bin/go" ]]; then
        echo "$("$HOME/.local/go/bin/go" version | awk '{print $3}' | sed 's/^go//')"
    fi
}

detect_node() {
    if [[ -x "$HOME/.local/node/bin/node" ]]; then
        echo "$("$HOME/.local/node/bin/node" -v | sed 's/^v//')"
    fi
}

detect_orb() {
    if [[ -d "/Applications/OrbStack.app" ]]; then
        defaults read "/Applications/OrbStack.app/Contents/Info.plist" CFBundleShortVersionString 2>/dev/null || echo ""
    fi
}

detect_vscode() {
    if [[ -d "/Applications/Visual Studio Code.app" ]]; then
        defaults read "/Applications/Visual Studio Code.app/Contents/Info.plist" CFBundleShortVersionString 2>/dev/null || echo ""
    fi
}

detect_python() {
    if command -v python3 &>/dev/null; then
        python3 --version 2>&1 | awk '{print $2}' || echo ""
    fi
}

detect_claude() {
    if [[ -d "/Applications/Claude.app" ]]; then
        defaults read "/Applications/Claude.app/Contents/Info.plist" CFBundleShortVersionString 2>/dev/null || echo ""
    fi
}

detect_rust() {
    if [[ -x "$HOME/.cargo/bin/rustc" ]]; then
        "$HOME/.cargo/bin/rustc" --version | awk '{print $2}' || echo ""
    fi
}

detect_git() {
    if command -v git &>/dev/null && xcode-select -p &>/dev/null; then
        git --version 2>/dev/null | awk '{print $3}' || echo ""
    fi
}

detect_compass() {
    if [[ -d "/Applications/MongoDB Compass.app" ]]; then
        defaults read "/Applications/MongoDB Compass.app/Contents/Info.plist" CFBundleShortVersionString 2>/dev/null || echo ""
    fi
}

detect_dbeaver() {
    if [[ -d "/Applications/DBeaver.app" ]]; then
        defaults read "/Applications/DBeaver.app/Contents/Info.plist" CFBundleShortVersionString 2>/dev/null || echo ""
    fi
}

detect_chrome() {
    if [[ -d "/Applications/Google Chrome.app" ]]; then
        defaults read "/Applications/Google Chrome.app/Contents/Info.plist" CFBundleShortVersionString 2>/dev/null || echo ""
    fi
}

detect_android_studio() {
    if [[ -d "/Applications/Android Studio.app" ]]; then
        defaults read "/Applications/Android Studio.app/Contents/Info.plist" CFBundleShortVersionString 2>/dev/null || echo ""
    fi
}

detect_codex() {
    if [[ -d "/Applications/Codex.app" ]]; then
        defaults read "/Applications/Codex.app/Contents/Info.plist" CFBundleShortVersionString 2>/dev/null || echo ""
    fi
}

detect_antigravity() {
    if [[ -d "/Applications/Antigravity.app" ]]; then
        defaults read "/Applications/Antigravity.app/Contents/Info.plist" CFBundleShortVersionString 2>/dev/null || echo ""
    fi
}

format_status() {
    local installed="$1"
    local latest="$2"
    if [[ -z "$installed" ]]; then
        echo -e "${RED}[Not Installed]${NC}"
    elif [[ "$installed" == "$latest" ]]; then
        echo -e "${GREEN}[Installed: v$installed (Latest)]${NC}"
    else
        echo -e "${YELLOW}[Installed: v$installed -> Upgrade to v$latest]${NC}"
    fi
}

format_git_status() {
    local installed="$1"
    if [[ -z "$installed" ]]; then
        echo -e "${RED}[Not Installed]${NC}"
    else
        echo -e "${GREEN}[Installed: v$installed (System Managed)]${NC}"
    fi
}

show_checkbox() {
    local val="$1"
    if [ "$val" -eq 1 ]; then
        echo -e "[${GREEN}✓${NC}]"
    else
        echo -e "[ ]"
    fi
}

show_line() {
    local line_num="$1"
    local content="$2"
    if [ "$CURSOR" -eq "$line_num" ]; then
        echo -e "${CYAN}❯${NC} $content"
    else
        echo -e "  $content"
    fi
}

update_env_block() {
    local marker="$1"
    local content="$2"
    local env_file="$HOME/.zsh/setup-zsh/env.zsh"
    
    mkdir -p "$(dirname "$env_file")"
    touch "$env_file"
    
    local temp_file
    temp_file=$(mktemp /tmp/env_zsh.XXXXXX)
    awk -v start="# >>> ${marker} >>>" -v end="# <<< ${marker} <<<" '
        $0 == start {p=1; next}
        $0 == end {p=0; next}
        !p
    ' "$env_file" > "$temp_file"
    
    if [[ -n "$content" ]]; then
        echo -e "# >>> ${marker} >>>\n${content}\n# <<< ${marker} <<<" >> "$temp_file"
    fi
    
    mv "$temp_file" "$env_file"
}

confirm_reinstall() {
    local name="$1"
    local version="$2"
    echo -n -e "${YELLOW}${name} is already up-to-date (v${version}). Re-install? (y/N): ${NC}"
    read -r response
    if [[ "$response" =~ ^[Yy]$ ]]; then
        return 0
    else
        return 1
    fi
}

install_go() {
    echo -e "${BLUE}Installing Go v${LATEST_GO}...${NC}"
    local download_url="https://dl.google.com/go/go${LATEST_GO}.darwin-${GO_ARCH}.tar.gz"
    local temp_tar=$(mktemp /tmp/go.XXXXXX.tar.gz)
    
    echo "Downloading ${download_url}..."
    if ! curl -L --progress-bar "$download_url" -o "$temp_tar"; then
        echo -e "${RED}Error: Failed to download Go.${NC}"
        return 1
    fi
    
    echo "Extracting to ~/.local/go..."
    mkdir -p "$HOME/.local"
    rm -rf "$HOME/.local/go"
    if ! tar -xzf "$temp_tar" -C "$HOME/.local"; then
        echo -e "${RED}Error: Failed to extract Go.${NC}"
        rm -f "$temp_tar"
        return 1
    fi
    
    rm -f "$temp_tar"
    
    echo "Updating env.zsh..."
    local content="export GOROOT=\"\$HOME/.local/go\"\nexport GOPATH=\"\$HOME/go\"\nexport PATH=\"\$GOROOT/bin:\$GOPATH/bin:\$PATH\""
    update_env_block "Go" "$content"
    
    echo -e "${GREEN}✓ Go v${LATEST_GO} installed successfully!${NC}"
}

install_node() {
    local version="$1"
    echo -e "${BLUE}Installing Node.js v${version}...${NC}"
    local download_url="https://nodejs.org/dist/v${version}/node-v${version}-darwin-${NODE_ARCH}.tar.gz"
    local temp_tar=$(mktemp /tmp/node.XXXXXX.tar.gz)
    
    echo "Downloading ${download_url}..."
    if ! curl -L --progress-bar "$download_url" -o "$temp_tar"; then
        echo -e "${RED}Error: Failed to download Node.js.${NC}"
        return 1
    fi
    
    echo "Extracting to ~/.local/node..."
    mkdir -p "$HOME/.local"
    rm -rf "$HOME/.local/node"
    local temp_extract_dir
    temp_extract_dir=$(mktemp -d /tmp/node_extract.XXXXXX)
    if ! tar -xzf "$temp_tar" -C "$temp_extract_dir"; then
        echo -e "${RED}Error: Failed to extract Node.js.${NC}"
        rm -f "$temp_tar"
        rm -rf "$temp_extract_dir"
        return 1
    fi
    
    mv "$temp_extract_dir"/node-v${version}-darwin-${NODE_ARCH} "$HOME/.local/node"
    
    rm -f "$temp_tar"
    rm -rf "$temp_extract_dir"
    
    echo "Updating env.zsh..."
    local content="export PATH=\"\$HOME/.local/node/bin:\$PATH\""
    update_env_block "Node" "$content"
    
    echo -e "${GREEN}✓ Node.js v${version} installed successfully!${NC}"
    echo -e "${YELLOW}Note: Global npm packages will be installed under ~/.local/node without requiring sudo!${NC}"
}

install_orb() {
    echo -e "${BLUE}Installing OrbStack v${LATEST_ORB}...${NC}"
    local download_url
    download_url=$(curl -s "https://cdn-updates.orbstack.dev/${ORB_ARCH}/appcast.new.xml" | grep -o 'enclosure url="[^"]*"' | head -n 1 | cut -d'"' -f2 || echo "")
    if [[ -z "$download_url" ]]; then
        echo -e "${RED}Error: Failed to resolve OrbStack download URL.${NC}"
        return 1
    fi
    
    local temp_dmg=$(mktemp /tmp/orbstack.XXXXXX.dmg)
    
    echo "Downloading ${download_url}..."
    if ! curl -L --progress-bar "$download_url" -o "$temp_dmg"; then
        echo -e "${RED}Error: Failed to download OrbStack.${NC}"
        return 1
    fi
    
    echo "Mounting DMG..."
    local mount_point="/Volumes/OrbStack_temp_$$"
    mkdir -p "$mount_point"
    if ! hdiutil attach -nobrowse -readonly -mountpoint "$mount_point" "$temp_dmg"; then
        echo -e "${RED}Error: Failed to mount OrbStack DMG.${NC}"
        rm -f "$temp_dmg"
        rm -rf "$mount_point"
        return 1
    fi
    
    echo "Copying to Applications..."
    rm -rf "/Applications/OrbStack.app"
    if ! cp -R "${mount_point}/OrbStack.app" "/Applications/"; then
        echo -e "${RED}Error: Failed to copy OrbStack to /Applications.${NC}"
        hdiutil detach "$mount_point"
        rm -f "$temp_dmg"
        rm -rf "$mount_point"
        return 1
    fi
    
    echo "Unmounting DMG..."
    hdiutil detach "$mount_point"
    rm -rf "$mount_point"
    rm -f "$temp_dmg"
    
    echo "Updating env.zsh..."
    local content="if [[ -d \"/Applications/OrbStack.app/Contents/MacOS/bin\" ]]; then\n  export PATH=\"/Applications/OrbStack.app/Contents/MacOS/bin:\$PATH\"\nfi"
    update_env_block "OrbStack" "$content"
    
    echo -e "${GREEN}✓ OrbStack v${LATEST_ORB} installed to /Applications/OrbStack.app!${NC}"
    echo -e "${YELLOW}Please launch OrbStack to complete system setup: open -a OrbStack${NC}"
}

install_vscode() {
    echo -e "${BLUE}Installing VSCode v${LATEST_VSCODE}...${NC}"
    local download_url="https://update.code.visualstudio.com/latest/darwin-universal/stable"
    local temp_zip=$(mktemp /tmp/vscode.XXXXXX.zip)
    
    echo "Downloading ${download_url}..."
    if ! curl -L --progress-bar "$download_url" -o "$temp_zip"; then
        echo -e "${RED}Error: Failed to download VSCode.${NC}"
        return 1
    fi
    
    echo "Extracting..."
    local temp_extract_dir
    temp_extract_dir=$(mktemp -d /tmp/vscode_extract.XXXXXX)
    if ! unzip -q "$temp_zip" -d "$temp_extract_dir"; then
        echo -e "${RED}Error: Failed to extract VSCode.${NC}"
        rm -f "$temp_zip"
        rm -rf "$temp_extract_dir"
        return 1
    fi
    
    echo "Moving to Applications..."
    rm -rf "/Applications/Visual Studio Code.app"
    if ! cp -R "$temp_extract_dir/Visual Studio Code.app" "/Applications/"; then
        echo -e "${RED}Error: Failed to copy VSCode to /Applications.${NC}"
        rm -f "$temp_zip"
        rm -rf "$temp_extract_dir"
        return 1
    fi
    
    rm -f "$temp_zip"
    rm -rf "$temp_extract_dir"
    
    echo "Updating env.zsh..."
    local content="export PATH=\"/Applications/Visual Studio Code.app/Contents/Resources/app/bin:\$PATH\""
    update_env_block "VSCode" "$content"
    
    echo -e "${GREEN}✓ VSCode v${LATEST_VSCODE} installed to /Applications/Visual Studio Code.app!${NC}"
}

install_python() {
    echo -e "${BLUE}Installing Python v${LATEST_PYTHON}...${NC}"
    local download_url="https://www.python.org/ftp/python/${LATEST_PYTHON}/python-${LATEST_PYTHON}-macos11.pkg"
    local temp_pkg=$(mktemp /tmp/python.XXXXXX.pkg)
    
    echo "Downloading ${download_url}..."
    if ! curl -L --progress-bar "$download_url" -o "$temp_pkg"; then
        echo -e "${RED}Error: Failed to download Python.${NC}"
        return 1
    fi
    
    echo -e "${YELLOW}This installation requires administrator privileges. Please enter your password when prompted.${NC}"
    if ! sudo installer -pkg "$temp_pkg" -target /; then
        echo -e "${RED}Error: Failed to install Python pkg.${NC}"
        rm -f "$temp_pkg"
        return 1
    fi
    
    rm -f "$temp_pkg"
    
    echo "Updating env.zsh..."
    local content="alias python=\"python3\"\nalias pip=\"pip3\""
    update_env_block "Python" "$content"
    
    echo -e "${GREEN}✓ Python v${LATEST_PYTHON} installed successfully!${NC}"
}

install_claude() {
    echo -e "${BLUE}Installing Claude v${LATEST_CLAUDE}...${NC}"
    local download_url
    download_url=$(curl -s https://downloads.claude.ai/releases/darwin/universal/RELEASES.json | grep -o 'https://downloads.claude.ai/releases/darwin/universal/[^"]*' | head -n 1 || echo "")
    if [[ -z "$download_url" ]]; then
        echo -e "${RED}Error: Failed to resolve Claude download URL.${NC}"
        return 1
    fi
    
    local temp_zip=$(mktemp /tmp/claude.XXXXXX.zip)
    
    echo "Downloading ${download_url}..."
    if ! curl -L --progress-bar "$download_url" -o "$temp_zip"; then
        echo -e "${RED}Error: Failed to download Claude.${NC}"
        return 1
    fi
    
    echo "Extracting..."
    local temp_extract_dir
    temp_extract_dir=$(mktemp -d /tmp/claude_extract.XXXXXX)
    if ! unzip -q "$temp_zip" -d "$temp_extract_dir"; then
        echo -e "${RED}Error: Failed to extract Claude.${NC}"
        rm -f "$temp_zip"
        rm -rf "$temp_extract_dir"
        return 1
    fi
    
    echo "Moving to Applications..."
    rm -rf "/Applications/Claude.app"
    if ! cp -R "$temp_extract_dir/Claude.app" "/Applications/"; then
        echo -e "${RED}Error: Failed to copy Claude to /Applications.${NC}"
        rm -f "$temp_zip"
        rm -rf "$temp_extract_dir"
        return 1
    fi
    
    rm -f "$temp_zip"
    rm -rf "$temp_extract_dir"
    
    echo -e "${GREEN}✓ Claude v${LATEST_CLAUDE} installed to /Applications/Claude.app!${NC}"
}

install_rust() {
    echo -e "${BLUE}Installing/Upgrading Rust v${LATEST_RUST}...${NC}"
    
    if [[ -x "$HOME/.cargo/bin/rustup" ]]; then
        echo "Updating Rust via rustup..."
        if ! "$HOME/.cargo/bin/rustup" update; then
            echo -e "${RED}Error: Failed to update Rust.${NC}"
            return 1
        fi
    else
        echo "Running official rustup installer..."
        if ! curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --no-modify-path; then
            echo -e "${RED}Error: Failed to install Rust via rustup.${NC}"
            return 1
        fi
    fi
    
    echo "Updating env.zsh..."
    local content="export PATH=\"\$HOME/.cargo/bin:\$PATH\""
    update_env_block "Rust" "$content"
    
    echo -e "${GREEN}✓ Rust v${LATEST_RUST} installed successfully!${NC}"
}

install_git() {
    echo -e "${BLUE}Installing Git via Xcode Command Line Tools...${NC}"
    if xcode-select -p &>/dev/null; then
        echo -e "${GREEN}✓ Xcode Command Line Tools are already installed.${NC}"
        echo -e "${YELLOW}Note: Git on macOS is managed by Xcode Command Line Tools.${NC}"
    else
        echo "Triggering Apple Xcode Command Line Tools installer..."
        xcode-select --install
        echo -e "${YELLOW}Please follow the instructions in the macOS pop-up window to complete the installation.${NC}"
        echo "Once installed, restart your terminal or run this script again."
    fi
}

install_compass() {
    echo -e "${BLUE}Installing MongoDB Compass v${LATEST_COMPASS}...${NC}"
    local download_url="https://downloads.mongodb.com/compass/mongodb-compass-${LATEST_COMPASS}-darwin-${NODE_ARCH}.dmg"
    local temp_dmg=$(mktemp /tmp/mongodb-compass.XXXXXX.dmg)
    
    echo "Downloading ${download_url}..."
    if ! curl -L --progress-bar "$download_url" -o "$temp_dmg"; then
        echo -e "${RED}Error: Failed to download MongoDB Compass.${NC}"
        return 1
    fi
    
    echo "Mounting DMG..."
    local mount_point="/Volumes/Compass_temp_$$"
    mkdir -p "$mount_point"
    if ! hdiutil attach -nobrowse -readonly -mountpoint "$mount_point" "$temp_dmg"; then
        echo -e "${RED}Error: Failed to mount MongoDB Compass DMG.${NC}"
        rm -f "$temp_dmg"
        rm -rf "$mount_point"
        return 1
    fi
    
    echo "Copying to Applications..."
    rm -rf "/Applications/MongoDB Compass.app"
    if ! cp -R "${mount_point}/MongoDB Compass.app" "/Applications/"; then
        echo -e "${RED}Error: Failed to copy MongoDB Compass to /Applications.${NC}"
        hdiutil detach "$mount_point"
        rm -f "$temp_dmg"
        rm -rf "$mount_point"
        return 1
    fi
    
    echo "Unmounting DMG..."
    hdiutil detach "$mount_point"
    rm -rf "$mount_point"
    rm -f "$temp_dmg"
    
    echo -e "${GREEN}✓ MongoDB Compass v${LATEST_COMPASS} installed to /Applications/MongoDB Compass.app!${NC}"
}

install_dbeaver() {
    echo -e "${BLUE}Installing DBeaver Community Edition v${LATEST_DBEAVER}...${NC}"
    local download_url="https://dbeaver.io/files/${LATEST_DBEAVER}/dbeaver-ce-${LATEST_DBEAVER}-macos-${DBEAVER_ARCH}.dmg"
    local temp_dmg=$(mktemp /tmp/dbeaver.XXXXXX.dmg)
    
    echo "Downloading ${download_url}..."
    if ! curl -L --progress-bar "$download_url" -o "$temp_dmg"; then
        echo -e "${RED}Error: Failed to download DBeaver.${NC}"
        return 1
    fi
    
    echo "Mounting DMG..."
    local mount_point="/Volumes/DBeaver_temp_$$"
    mkdir -p "$mount_point"
    if ! hdiutil attach -nobrowse -readonly -mountpoint "$mount_point" "$temp_dmg"; then
        echo -e "${RED}Error: Failed to mount DBeaver DMG.${NC}"
        rm -f "$temp_dmg"
        rm -rf "$mount_point"
        return 1
    fi
    
    echo "Copying to Applications..."
    rm -rf "/Applications/DBeaver.app"
    if ! cp -R "${mount_point}/DBeaver.app" "/Applications/"; then
        echo -e "${RED}Error: Failed to copy DBeaver to /Applications.${NC}"
        hdiutil detach "$mount_point"
        rm -f "$temp_dmg"
        rm -rf "$mount_point"
        return 1
    fi
    
    echo "Unmounting DMG..."
    hdiutil detach "$mount_point"
    rm -rf "$mount_point"
    rm -f "$temp_dmg"
    
    echo -e "${GREEN}✓ DBeaver Community Edition v${LATEST_DBEAVER} installed to /Applications/DBeaver.app!${NC}"
}

install_chrome() {
    echo -e "${BLUE}Installing Google Chrome v${LATEST_CHROME}...${NC}"
    local download_url="https://dl.google.com/chrome/mac/universal/stable/GGRO/googlechrome.dmg"
    local temp_dmg=$(mktemp /tmp/googlechrome.XXXXXX.dmg)
    
    echo "Downloading ${download_url}..."
    if ! curl -L --progress-bar "$download_url" -o "$temp_dmg"; then
        echo -e "${RED}Error: Failed to download Google Chrome.${NC}"
        return 1
    fi
    
    echo "Mounting DMG..."
    local mount_point="/Volumes/Chrome_temp_$$"
    mkdir -p "$mount_point"
    if ! hdiutil attach -nobrowse -readonly -mountpoint "$mount_point" "$temp_dmg"; then
        echo -e "${RED}Error: Failed to mount Google Chrome DMG.${NC}"
        rm -f "$temp_dmg"
        rm -rf "$mount_point"
        return 1
    fi
    
    echo "Copying to Applications..."
    rm -rf "/Applications/Google Chrome.app"
    if ! cp -R "${mount_point}/Google Chrome.app" "/Applications/"; then
        echo -e "${RED}Error: Failed to copy Google Chrome to /Applications.${NC}"
        hdiutil detach "$mount_point"
        rm -f "$temp_dmg"
        rm -rf "$mount_point"
        return 1
    fi
    
    echo "Unmounting DMG..."
    hdiutil detach "$mount_point"
    rm -rf "$mount_point"
    rm -f "$temp_dmg"
    
    echo -e "${GREEN}✓ Google Chrome v${LATEST_CHROME} installed to /Applications/Google Chrome.app!${NC}"
}

install_android_studio() {
    echo -e "${BLUE}Installing Android Studio v${LATEST_ANDROID_STUDIO}...${NC}"
    local download_url
    download_url=$(curl -s https://formulae.brew.sh/api/cask/android-studio.json | grep -o '"url":"[^"]*"' | head -n 1 | cut -d'"' -f4)
    if [ "$ARCH" = "x86_64" ]; then
        download_url="${download_url/_arm.dmg/.dmg}"
    fi
    local temp_dmg=$(mktemp /tmp/android-studio.XXXXXX.dmg)
    
    echo "Downloading ${download_url}..."
    if ! curl -L --progress-bar "$download_url" -o "$temp_dmg"; then
        echo -e "${RED}Error: Failed to download Android Studio.${NC}"
        return 1
    fi
    
    echo "Mounting DMG..."
    local mount_point="/Volumes/AndroidStudio_temp_$$"
    mkdir -p "$mount_point"
    if ! hdiutil attach -nobrowse -readonly -mountpoint "$mount_point" "$temp_dmg"; then
        echo -e "${RED}Error: Failed to mount Android Studio DMG.${NC}"
        rm -f "$temp_dmg"
        rm -rf "$mount_point"
        return 1
    fi
    
    echo "Copying to Applications..."
    rm -rf "/Applications/Android Studio.app"
    if ! cp -R "${mount_point}/Android Studio.app" "/Applications/"; then
        echo -e "${RED}Error: Failed to copy Android Studio to /Applications.${NC}"
        hdiutil detach "$mount_point"
        rm -f "$temp_dmg"
        rm -rf "$mount_point"
        return 1
    fi
    
    echo "Unmounting DMG..."
    hdiutil detach "$mount_point"
    rm -rf "$mount_point"
    rm -f "$temp_dmg"

    echo "Updating env.zsh with Android SDK environment variables..."
    local content="export ANDROID_HOME=\"\$HOME/Library/Android/sdk\"\nexport ANDROID_SDK_ROOT=\"\$HOME/Library/Android/sdk\"\nexport PATH=\"\$ANDROID_HOME/emulator:\$ANDROID_HOME/platform-tools:\$ANDROID_HOME/cmdline-tools/latest/bin:\$ANDROID_HOME/tools:\$ANDROID_HOME/tools/bin:\$PATH\""
    update_env_block "AndroidStudio" "$content"
    echo -e "${GREEN}✓ Android Studio v${LATEST_ANDROID_STUDIO} installed to /Applications/Android Studio.app!${NC}"
}

install_codex() {
    echo -e "${BLUE}Installing Codex v${LATEST_CODEX}...${NC}"
    local download_url
    download_url=$(curl -s https://formulae.brew.sh/api/cask/codex-app.json | grep -o '"url":"[^"]*"' | head -n 1 | cut -d'"' -f4)
    if [ "$ARCH" = "x86_64" ]; then
        download_url="${download_url/darwin-arm64/darwin-x64}"
    fi
    local temp_zip=$(mktemp /tmp/codex.XXXXXX.zip)
    
    echo "Downloading ${download_url}..."
    if ! curl -L --progress-bar "$download_url" -o "$temp_zip"; then
        echo -e "${RED}Error: Failed to download Codex.${NC}"
        return 1
    fi
    
    echo "Extracting Codex.app..."
    local temp_dir
    temp_dir=$(mktemp -d /tmp/codex_extract.XXXXXX)
    if ! unzip -q -o "$temp_zip" -d "$temp_dir"; then
        echo -e "${RED}Error: Failed to extract Codex zip.${NC}"
        rm -f "$temp_zip"
        rm -rf "$temp_dir"
        return 1
    fi
    
    echo "Copying to Applications..."
    rm -rf "/Applications/Codex.app"
    if ! cp -R "${temp_dir}/Codex.app" "/Applications/"; then
        echo -e "${RED}Error: Failed to copy Codex.app to /Applications.${NC}"
        rm -rf "$temp_dir"
        rm -f "$temp_zip"
        return 1
    fi
    
    rm -rf "$temp_dir"
    rm -f "$temp_zip"
    
    echo -e "${GREEN}✓ Codex v${LATEST_CODEX} installed to /Applications/Codex.app!${NC}"
}

install_antigravity() {
    echo -e "${BLUE}Installing Antigravity v${LATEST_ANTIGRAVITY}...${NC}"
    local download_url
    download_url=$(curl -s https://formulae.brew.sh/api/cask/antigravity.json | grep -o '"url":"[^"]*"' | head -n 1 | cut -d'"' -f4)
    if [ "$ARCH" = "x86_64" ]; then
        download_url="${download_url/darwin-arm/darwin-x64}"
    fi
    local temp_dmg=$(mktemp /tmp/antigravity.XXXXXX.dmg)
    
    echo "Downloading ${download_url}..."
    if ! curl -L --progress-bar "$download_url" -o "$temp_dmg"; then
        echo -e "${RED}Error: Failed to download Antigravity.${NC}"
        return 1
    fi
    
    echo "Mounting DMG..."
    local mount_point="/Volumes/Antigravity_temp_$$"
    mkdir -p "$mount_point"
    if ! hdiutil attach -nobrowse -readonly -mountpoint "$mount_point" "$temp_dmg"; then
        echo -e "${RED}Error: Failed to mount Antigravity DMG.${NC}"
        rm -f "$temp_dmg"
        rm -rf "$mount_point"
        return 1
    fi
    
    echo "Copying to Applications..."
    rm -rf "/Applications/Antigravity.app"
    if ! cp -R "${mount_point}/Antigravity.app" "/Applications/"; then
        echo -e "${RED}Error: Failed to copy Antigravity to /Applications.${NC}"
        hdiutil detach "$mount_point"
        rm -f "$temp_dmg"
        rm -rf "$mount_point"
        return 1
    fi
    
    echo "Unmounting DMG..."
    hdiutil detach "$mount_point"
    rm -rf "$mount_point"
    rm -f "$temp_dmg"
    
    echo -e "${GREEN}✓ Antigravity v${LATEST_ANTIGRAVITY} installed to /Applications/Antigravity.app!${NC}"
}

# Selection states (0 = unselected, 1 = selected)
SEL_1=0; SEL_2=0; SEL_3=0; SEL_4=0; SEL_5=0; SEL_6=0; SEL_7=0; SEL_8=0; SEL_9=0; SEL_10=0; SEL_11=0; SEL_12=0; SEL_13=0; SEL_14=0
CURSOR=1
do_install=0

toggle_all() {
    local any_unselected=0
    for i in {1..14}; do
        eval "local val=\$SEL_$i"
        if [ "$val" -eq 0 ]; then
            any_unselected=1
            break
        fi
    done
    
    for i in {1..14}; do
        if [ "$any_unselected" -eq 1 ]; then
            eval "SEL_$i=1"
        else
            eval "SEL_$i=0"
        fi
    done
}

# Main loop
while true; do
    INST_GO=$(detect_go)
    INST_NODE=$(detect_node)
    INST_ORB=$(detect_orb)
    INST_VSCODE=$(detect_vscode)
    INST_PYTHON=$(detect_python)
    INST_CLAUDE=$(detect_claude)
    INST_RUST=$(detect_rust)
    INST_GIT=$(detect_git)
    INST_COMPASS=$(detect_compass)
    INST_DBEAVER=$(detect_dbeaver)
    INST_CHROME=$(detect_chrome)
    INST_ANDROID_STUDIO=$(detect_android_studio)
    INST_CODEX=$(detect_codex)
    INST_ANTIGRAVITY=$(detect_antigravity)
    
    if [[ -n "$TERM" ]]; then
        clear
    fi
    echo -e "${BLUE}==================================================${NC}"
    echo -e "${BLUE}        🛠️  setup-zsh Developer Tool Installer${NC}"
    echo -e "${BLUE}==================================================${NC}"
    echo -e "Use Up/Down arrows to navigate, Space/Enter to toggle selections.\n"
    
    echo -e "${PURPLE}── Languages & Runtimes ─────────────────────────${NC}"
    show_line 1 "$(show_checkbox "$SEL_1")  1) 🐹 Go (Golang)        $(format_status "$INST_GO" "$LATEST_GO")"
    show_line 2 "$(show_checkbox "$SEL_2")  2) 🟢 Node.js            $(format_status "$INST_NODE" "$LATEST_NODE")"
    show_line 3 "$(show_checkbox "$SEL_3")  3) 🐍 Python             $(format_status "$INST_PYTHON" "$LATEST_PYTHON")"
    show_line 4 "$(show_checkbox "$SEL_4")  4) 🦀 Rust               $(format_status "$INST_RUST" "$LATEST_RUST")"
    
    echo -e "${PURPLE}── Dev Tools & Infrastructure ───────────────────${NC}"
    show_line 5 "$(show_checkbox "$SEL_5")  5) 🐙 Git                $(format_git_status "$INST_GIT")"
    show_line 6 "$(show_checkbox "$SEL_6")  6) 🔮 OrbStack           $(format_status "$INST_ORB" "$LATEST_ORB")"
    
    echo -e "${PURPLE}── IDEs & Editors ───────────────────────────────${NC}"
    show_line 7 "$(show_checkbox "$SEL_7")  7) 🤖 Android Studio     $(format_status "$INST_ANDROID_STUDIO" "$LATEST_ANDROID_STUDIO")"
    show_line 8 "$(show_checkbox "$SEL_8")  8) 🟦 VSCode             $(format_status "$INST_VSCODE" "$LATEST_VSCODE")"
    
    echo -e "${PURPLE}── Database Tools ───────────────────────────────${NC}"
    show_line 9 "$(show_checkbox "$SEL_9")  9) 🐿️ DBeaver            $(format_status "$INST_DBEAVER" "$LATEST_DBEAVER")"
    show_line 10 "$(show_checkbox "$SEL_10") 10) 🍃 MongoDB Compass    $(format_status "$INST_COMPASS" "$LATEST_COMPASS")"
    
    echo -e "${PURPLE}── Applications & AI ────────────────────────────${NC}"
    show_line 11 "$(show_checkbox "$SEL_11") 11) 🚀 Antigravity        $(format_status "$INST_ANTIGRAVITY" "$LATEST_ANTIGRAVITY")"
    show_line 12 "$(show_checkbox "$SEL_12") 12) 💥 Claude             $(format_status "$INST_CLAUDE" "$LATEST_CLAUDE")"
    show_line 13 "$(show_checkbox "$SEL_13") 13) 🧠 Codex              $(format_status "$INST_CODEX" "$LATEST_CODEX")"
    show_line 14 "$(show_checkbox "$SEL_14") 14) 🌐 Google Chrome      $(format_status "$INST_CHROME" "$LATEST_CHROME")"
    echo ""
    show_line 15 "[I] Install Selected Tools"
    show_line 16 "[A] Toggle All"
    show_line 17 "[E] Exit"
    echo -e "${BLUE}==================================================${NC}"
    
    # Read one character (escape sequences check)
    IFS= read -r -s -n 1 key 2>/dev/null
    action=""
    
    if [[ "$key" = $'\e' ]]; then
        read -r -s -n 2 -t 1 next_chars 2>/dev/null
        if [[ "$next_chars" = "[A" || "$next_chars" = "OA" ]]; then
            action="UP"
        elif [[ "$next_chars" = "[B" || "$next_chars" = "OB" ]]; then
            action="DOWN"
        fi
    elif [[ "$key" = " " ]]; then
        action="SPACE"
    elif [[ -z "$key" ]]; then
        action="ENTER"
    elif [[ "$key" = "i" || "$key" = "I" ]]; then
        action="INSTALL"
    elif [[ "$key" = "a" || "$key" = "A" ]]; then
        action="ALL"
    elif [[ "$key" = "e" || "$key" = "E" || "$key" = "q" || "$key" = "Q" ]]; then
        action="EXIT"
    elif [[ "$key" =~ ^[1-9]$ ]]; then
        action="NUM_$key"
    fi
    
    case "$action" in
        UP)
            CURSOR=$((CURSOR - 1))
            if [ "$CURSOR" -lt 1 ]; then
                CURSOR=17
            fi
            ;;
        DOWN)
            CURSOR=$((CURSOR + 1))
            if [ "$CURSOR" -gt 17 ]; then
                CURSOR=1
            fi
            ;;
        SPACE|ENTER)
            if [ "$CURSOR" -ge 1 ] && [ "$CURSOR" -le 14 ]; then
                eval "SEL_$CURSOR=\$((1 - SEL_$CURSOR))"
            elif [ "$CURSOR" -eq 15 ]; then
                do_install=1
            elif [ "$CURSOR" -eq 16 ]; then
                toggle_all
            elif [ "$CURSOR" -eq 17 ]; then
                echo -e "\n${BLUE}Goodbye!${NC}"
                exit 0
            fi
            ;;
        NUM_*)
            num="${action#NUM_}"
            eval "SEL_$num=\$((1 - SEL_$num))"
            ;;
        INSTALL)
            do_install=1
            ;;
        ALL)
            toggle_all
            ;;
        EXIT)
            echo -e "\n${BLUE}Goodbye!${NC}"
            exit 0
            ;;
    esac
    
    if [ "$do_install" -eq 1 ]; then
        do_install=0 # Reset flag
        
        # Count selected tools
        count=0
        for i in {1..14}; do
            eval "val=\$SEL_$i"
            if [ "$val" -eq 1 ]; then
                count=$((count + 1))
            fi
        done
        
        if [ "$count" -eq 0 ]; then
            echo -e "\n${YELLOW}No tools selected. Use Up/Down + Space or numbers 1-9 to select.${NC}"
            echo -e "\nPress Enter to continue..."
            read -r
            continue
        fi
        
        echo -e "\n${BLUE}Starting installation of $count selected tool(s)...${NC}\n"
        
        # 1. Go
        if [ "$SEL_1" -eq 1 ]; then
            if [[ "$INST_GO" == "$LATEST_GO" ]] && ! confirm_reinstall "Go" "$LATEST_GO"; then
                echo "Skipping Go."
            else
                install_go
            fi
            echo ""
        fi
        
        # 2. Node.js
        if [ "$SEL_2" -eq 1 ]; then
            if [[ "$INST_NODE" == "$LATEST_NODE" ]] && ! confirm_reinstall "Node.js" "$LATEST_NODE"; then
                echo "Skipping Node.js."
            else
                install_node "$LATEST_NODE"
            fi
            echo ""
        fi
        
        # 3. Python
        if [ "$SEL_3" -eq 1 ]; then
            if [[ "$INST_PYTHON" == "$LATEST_PYTHON" ]] && ! confirm_reinstall "Python" "$LATEST_PYTHON"; then
                echo "Skipping Python."
            else
                install_python
            fi
            echo ""
        fi
        
        # 4. Rust
        if [ "$SEL_4" -eq 1 ]; then
            if [[ "$INST_RUST" == "$LATEST_RUST" ]] && ! confirm_reinstall "Rust" "$LATEST_RUST"; then
                echo "Skipping Rust."
            else
                install_rust
            fi
            echo ""
        fi
        
        # 5. Git
        if [ "$SEL_5" -eq 1 ]; then
            install_git
            echo ""
        fi
        
        # 6. OrbStack
        if [ "$SEL_6" -eq 1 ]; then
            if [[ "$INST_ORB" == "$LATEST_ORB" ]] && ! confirm_reinstall "OrbStack" "$LATEST_ORB"; then
                echo "Skipping OrbStack."
            else
                install_orb
            fi
            echo ""
        fi
        
        # 7. Android Studio
        if [ "$SEL_7" -eq 1 ]; then
            if [[ "$INST_ANDROID_STUDIO" == "$LATEST_ANDROID_STUDIO" ]] && ! confirm_reinstall "Android Studio" "$LATEST_ANDROID_STUDIO"; then
                echo "Skipping Android Studio."
            else
                install_android_studio
            fi
            echo ""
        fi
        
        # 8. VSCode
        if [ "$SEL_8" -eq 1 ]; then
            if [[ "$INST_VSCODE" == "$LATEST_VSCODE" ]] && ! confirm_reinstall "VSCode" "$LATEST_VSCODE"; then
                echo "Skipping VSCode."
            else
                install_vscode
            fi
            echo ""
        fi
        
        # 9. DBeaver
        if [ "$SEL_9" -eq 1 ]; then
            if [[ "$INST_DBEAVER" == "$LATEST_DBEAVER" ]] && ! confirm_reinstall "DBeaver Community Edition" "$LATEST_DBEAVER"; then
                echo "Skipping DBeaver Community Edition."
            else
                install_dbeaver
            fi
            echo ""
        fi
        
        # 10. MongoDB Compass
        if [ "$SEL_10" -eq 1 ]; then
            if [[ "$INST_COMPASS" == "$LATEST_COMPASS" ]] && ! confirm_reinstall "MongoDB Compass" "$LATEST_COMPASS"; then
                echo "Skipping MongoDB Compass."
            else
                install_compass
            fi
            echo ""
        fi
        
        # 11. Antigravity
        if [ "$SEL_11" -eq 1 ]; then
            if [[ "$INST_ANTIGRAVITY" == "$LATEST_ANTIGRAVITY" ]] && ! confirm_reinstall "Antigravity" "$LATEST_ANTIGRAVITY"; then
                echo "Skipping Antigravity."
            else
                install_antigravity
            fi
            echo ""
        fi
        
        # 12. Claude
        if [ "$SEL_12" -eq 1 ]; then
            if [[ "$INST_CLAUDE" == "$LATEST_CLAUDE" ]] && ! confirm_reinstall "Claude" "$LATEST_CLAUDE"; then
                echo "Skipping Claude."
            else
                install_claude
            fi
            echo ""
        fi
        
        # 13. Codex
        if [ "$SEL_13" -eq 1 ]; then
            if [[ "$INST_CODEX" == "$LATEST_CODEX" ]] && ! confirm_reinstall "Codex" "$LATEST_CODEX"; then
                echo "Skipping Codex."
            else
                install_codex
            fi
            echo ""
        fi
        
        # 14. Google Chrome
        if [ "$SEL_14" -eq 1 ]; then
            if [[ "$INST_CHROME" == "$LATEST_CHROME" ]] && ! confirm_reinstall "Google Chrome" "$LATEST_CHROME"; then
                echo "Skipping Google Chrome."
            else
                install_chrome
            fi
            echo ""
        fi
        
        # Reset selections after installation
        SEL_1=0; SEL_2=0; SEL_3=0; SEL_4=0; SEL_5=0; SEL_6=0; SEL_7=0; SEL_8=0; SEL_9=0; SEL_10=0; SEL_11=0; SEL_12=0; SEL_13=0; SEL_14=0
        
        echo -e "${GREEN}Batch installation completed!${NC}"
        echo -e "Please run ${YELLOW}source ~/.zshrc${NC} to load environment changes."
        echo -e "\nPress Enter to return to the menu..."
        read -r
    fi
done
