# Selection states (0 = unselected, 1 = selected)
SEL_1=0; SEL_2=0; SEL_3=0; SEL_4=0; SEL_5=0; SEL_6=0; SEL_7=0; SEL_8=0; SEL_9=0; SEL_10=0; SEL_11=0; SEL_12=0; SEL_13=0; SEL_14=0; SEL_15=0; SEL_16=0
CURSOR=1
do_install=0

toggle_all() {
    local any_unselected=0
    for i in {1..16}; do
        eval "local val=\$SEL_$i"
        if [ "$val" -eq 0 ]; then
            any_unselected=1
            break
        fi
    done
    
    for i in {1..16}; do
        if [ "$any_unselected" -eq 1 ]; then
            eval "SEL_$i=1"
        else
            eval "SEL_$i=0"
        fi
    done
}

select_outdated() {
    for i in {1..16}; do
        eval "SEL_$i=0"
    done
    [[ -n "$INST_BUN" && "$INST_BUN" != "$LATEST_BUN" ]] && SEL_1=1
    [[ -n "$INST_GO" && "$INST_GO" != "$LATEST_GO" ]] && SEL_2=1
    [[ -n "$INST_JDK" && "$INST_JDK" != "$LATEST_JDK" ]] && SEL_3=1
    [[ -n "$INST_NODE" && "$INST_NODE" != "$LATEST_NODE" ]] && SEL_4=1
    if [[ -n "$INST_PYTHON" || -n "$INST_UV" ]]; then
        if [[ "$INST_PYTHON" != "$LATEST_PYTHON" || "$INST_UV" != "$LATEST_UV" || -z "$INST_PYTHON" || -z "$INST_UV" ]]; then
            SEL_5=1
        fi
    fi
    [[ -n "$INST_RUST" && "$INST_RUST" != "$LATEST_RUST" ]] && SEL_6=1
    [[ -n "$INST_ORB" && "$INST_ORB" != "$LATEST_ORB" ]] && SEL_8=1
    [[ -n "$INST_ANDROID_STUDIO" && "$INST_ANDROID_STUDIO" != "$LATEST_ANDROID_STUDIO" ]] && SEL_9=1
    [[ -n "$INST_VSCODE" && "$INST_VSCODE" != "$LATEST_VSCODE" ]] && SEL_10=1
    [[ -n "$INST_DBEAVER" && "$INST_DBEAVER" != "$LATEST_DBEAVER" ]] && SEL_11=1
    [[ -n "$INST_COMPASS" && "$INST_COMPASS" != "$LATEST_COMPASS" ]] && SEL_12=1
    [[ -n "$INST_ANTIGRAVITY" && "$INST_ANTIGRAVITY" != "$LATEST_ANTIGRAVITY" ]] && SEL_13=1
    [[ -n "$INST_CLAUDE" && "$INST_CLAUDE" != "$LATEST_CLAUDE" ]] && SEL_14=1
    [[ -n "$INST_CODEX" && "$INST_CODEX" != "$LATEST_CODEX" ]] && SEL_15=1
    [[ -n "$INST_CHROME" && "$INST_CHROME" != "$LATEST_CHROME" ]] && SEL_16=1
}

has_outdated_tools() {
    [[ -n "$INST_BUN" && "$INST_BUN" != "$LATEST_BUN" ]] && return 0
    [[ -n "$INST_GO" && "$INST_GO" != "$LATEST_GO" ]] && return 0
    [[ -n "$INST_JDK" && "$INST_JDK" != "$LATEST_JDK" ]] && return 0
    [[ -n "$INST_NODE" && "$INST_NODE" != "$LATEST_NODE" ]] && return 0
    if [[ -n "$INST_PYTHON" || -n "$INST_UV" ]]; then
        if [[ "$INST_PYTHON" != "$LATEST_PYTHON" || "$INST_UV" != "$LATEST_UV" || -z "$INST_PYTHON" || -z "$INST_UV" ]]; then
            return 0
        fi
    fi
    [[ -n "$INST_RUST" && "$INST_RUST" != "$LATEST_RUST" ]] && return 0
    [[ -n "$INST_ORB" && "$INST_ORB" != "$LATEST_ORB" ]] && return 0
    [[ -n "$INST_ANDROID_STUDIO" && "$INST_ANDROID_STUDIO" != "$LATEST_ANDROID_STUDIO" ]] && return 0
    [[ -n "$INST_VSCODE" && "$INST_VSCODE" != "$LATEST_VSCODE" ]] && return 0
    [[ -n "$INST_DBEAVER" && "$INST_DBEAVER" != "$LATEST_DBEAVER" ]] && return 0
    [[ -n "$INST_COMPASS" && "$INST_COMPASS" != "$LATEST_COMPASS" ]] && return 0
    [[ -n "$INST_ANTIGRAVITY" && "$INST_ANTIGRAVITY" != "$LATEST_ANTIGRAVITY" ]] && return 0
    [[ -n "$INST_CLAUDE" && "$INST_CLAUDE" != "$LATEST_CLAUDE" ]] && return 0
    [[ -n "$INST_CODEX" && "$INST_CODEX" != "$LATEST_CODEX" ]] && return 0
    [[ -n "$INST_CHROME" && "$INST_CHROME" != "$LATEST_CHROME" ]] && return 0
    return 1
}

refresh_installed_tools() {
    INST_BUN=$(detect_bun)
    INST_GO=$(detect_go)
    INST_NODE=$(detect_node)
    INST_ORB=$(detect_orb)
    INST_VSCODE=$(detect_vscode)
    INST_PYTHON=$(detect_python)
    INST_UV=$(detect_uv)
    INST_JDK=$(detect_jdk)
    INST_CLAUDE=$(detect_claude)
    INST_RUST=$(detect_rust)
    INST_GIT=$(detect_git)
    INST_COMPASS=$(detect_compass)
    INST_DBEAVER=$(detect_dbeaver)
    INST_CHROME=$(detect_chrome)
    INST_ANDROID_STUDIO=$(detect_android_studio)
    INST_CODEX=$(detect_codex)
    INST_ANTIGRAVITY=$(detect_antigravity)
}

cleanup_cursor() {
    printf "\033[?25h"
}
trap cleanup_cursor EXIT INT TERM

refresh_installed_tools

# Handle CLI flags (e.g. --update-all, update-all, -u)
if [[ "$1" == "--update-all" || "$1" == "update-all" || "$1" == "-u" || "$1" == "--all" || "$1" == "-a" ]]; then
    select_outdated
    do_install=1
else
    printf "\033[?25l"
fi

# Main loop
while true; do
    if [ "$do_install" -eq 0 ]; then
        max_cursor=19
        if has_outdated_tools; then
            max_cursor=20
        fi
        if [ "$CURSOR" -gt "$max_cursor" ]; then
            CURSOR=$max_cursor
        fi

        # Buffer entire menu, then flush at once to avoid flicker
        menu_buf=$(
            echo -e "${BLUE}==================================================${NC}\033[K"
            echo -e "${BLUE}        🛠️  setup-zsh Developer Tool Installer${NC}\033[K"
            echo -e "${BLUE}==================================================${NC}\033[K"
            echo -e "Use Up/Down/Left/Right arrows to navigate, Space/Enter to toggle.\033[K"
            echo ""
            echo -e "${PURPLE}── Languages & Runtimes ─────────────────────────${NC}\033[K"
            show_line 1 "$(show_checkbox "$SEL_1")  1) 🥟 Bun                $(format_status "$INST_BUN" "$LATEST_BUN")"
            show_line 2 "$(show_checkbox "$SEL_2")  2) 🐹 Go (Golang)        $(format_status "$INST_GO" "$LATEST_GO")"
            show_line 3 "$(show_checkbox "$SEL_3")  3) ☕ JDK (Temurin LTS)  $(format_status "$INST_JDK" "$LATEST_JDK")"
            show_line 4 "$(show_checkbox "$SEL_4")  4) 🟢 Node.js            $(format_status "$INST_NODE" "$LATEST_NODE")"
            show_line 5 "$(show_checkbox "$SEL_5")  5) 🐍 Python & uv        $(format_python_status "$INST_PYTHON" "$INST_UV")"
            show_line 6 "$(show_checkbox "$SEL_6")  6) 🦀 Rust               $(format_status "$INST_RUST" "$LATEST_RUST")"
            echo -e "${PURPLE}── Dev Tools & Infrastructure ───────────────────${NC}\033[K"
            show_line 7 "$(show_checkbox "$SEL_7")  7) 🐙 Git                $(format_git_status "$INST_GIT")"
            show_line 8 "$(show_checkbox "$SEL_8")  8) 🔮 OrbStack (Docker)  $(format_status "$INST_ORB" "$LATEST_ORB")"
            echo -e "${PURPLE}── IDEs & Editors ───────────────────────────────${NC}\033[K"
            show_line 9 "$(show_checkbox "$SEL_9")  9) 🤖 Android Studio     $(format_status "$INST_ANDROID_STUDIO" "$LATEST_ANDROID_STUDIO")"
            show_line 10 "$(show_checkbox "$SEL_10") 10) 🟦 VSCode             $(format_status "$INST_VSCODE" "$LATEST_VSCODE")"
            echo -e "${PURPLE}── Database Tools ───────────────────────────────${NC}\033[K"
            show_line 11 "$(show_checkbox "$SEL_11") 11) 🦫 DBeaver            $(format_status "$INST_DBEAVER" "$LATEST_DBEAVER")"
            show_line 12 "$(show_checkbox "$SEL_12") 12) 🧭 MongoDB Compass    $(format_status "$INST_COMPASS" "$LATEST_COMPASS")"
            echo -e "${PURPLE}── Applications & AI ────────────────────────────${NC}\033[K"
            show_line 13 "$(show_checkbox "$SEL_13") 13) 🚀 Antigravity        $(format_status "$INST_ANTIGRAVITY" "$LATEST_ANTIGRAVITY")"
            show_line 14 "$(show_checkbox "$SEL_14") 14) 💥 Claude             $(format_status "$INST_CLAUDE" "$LATEST_CLAUDE")"
            show_line 15 "$(show_checkbox "$SEL_15") 15) 🧠 Codex              $(format_status "$INST_CODEX" "$LATEST_CODEX")"
            show_line 16 "$(show_checkbox "$SEL_16") 16) 🌐 Google Chrome      $(format_status "$INST_CHROME" "$LATEST_CHROME")"
            echo -e "\033[K"
            if has_outdated_tools; then
                echo -e "$(show_action_item 17 "[I] Install")  $(show_action_item 18 "[A] Toggle All")  $(show_action_item 19 "[U] Select Outdated")  $(show_action_item 20 "[E] Exit")\033[K"
            else
                echo -e "$(show_action_item 17 "[I] Install")    $(show_action_item 18 "[A] Toggle All")    $(show_action_item 19 "[E] Exit")\033[K"
            fi
            echo -e "${BLUE}==================================================${NC}\033[K"
        )
        printf '\033[2J\033[H%s\n' "$menu_buf"
        
        # Read one character (escape sequences check)
        IFS= read -r -s -n 1 key 2>/dev/null
        action=""
        
        if [[ "$key" = $'\e' ]]; then
            read -r -s -n 2 -t 1 next_chars 2>/dev/null
            if [[ "$next_chars" = "[A" || "$next_chars" = "OA" ]]; then
                action="UP"
            elif [[ "$next_chars" = "[B" || "$next_chars" = "OB" ]]; then
                action="DOWN"
            elif [[ "$next_chars" = "[C" || "$next_chars" = "OC" ]]; then
                action="RIGHT"
            elif [[ "$next_chars" = "[D" || "$next_chars" = "OD" ]]; then
                action="LEFT"
            fi
        elif [[ "$key" = " " ]]; then
            action="SPACE"
        elif [[ -z "$key" ]]; then
            action="ENTER"
        elif [[ "$key" = "i" || "$key" = "I" ]]; then
            action="INSTALL"
        elif [[ "$key" = "a" || "$key" = "A" ]]; then
            action="ALL"
        elif [[ "$key" = "u" || "$key" = "U" ]]; then
            if has_outdated_tools; then
                action="OUTDATED"
            fi
        elif [[ "$key" = "e" || "$key" = "E" || "$key" = "q" || "$key" = "Q" ]]; then
            action="EXIT"
        elif [[ "$key" =~ ^[1-9]$ ]]; then
            action="NUM_$key"
        fi
        
        case "$action" in
            UP)
                if [ "$CURSOR" -ge 17 ]; then
                    CURSOR=16
                else
                    CURSOR=$((CURSOR - 1))
                    if [ "$CURSOR" -lt 1 ]; then
                        CURSOR=$max_cursor
                    fi
                fi
                ;;
            DOWN)
                if [ "$CURSOR" -eq 16 ]; then
                    CURSOR=17
                elif [ "$CURSOR" -ge 17 ]; then
                    CURSOR=1
                else
                    CURSOR=$((CURSOR + 1))
                fi
                ;;
            LEFT)
                if [ "$CURSOR" -ge 17 ]; then
                    CURSOR=$((CURSOR - 1))
                    if [ "$CURSOR" -lt 17 ]; then
                        CURSOR=$max_cursor
                    fi
                else
                    CURSOR=$((CURSOR - 1))
                    if [ "$CURSOR" -lt 1 ]; then
                        CURSOR=$max_cursor
                    fi
                fi
                ;;
            RIGHT)
                if [ "$CURSOR" -ge 17 ]; then
                    CURSOR=$((CURSOR + 1))
                    if [ "$CURSOR" -gt "$max_cursor" ]; then
                        CURSOR=17
                    fi
                else
                    CURSOR=$((CURSOR + 1))
                    if [ "$CURSOR" -gt "$max_cursor" ]; then
                        CURSOR=1
                    fi
                fi
                ;;
            SPACE|ENTER)
                if [ "$CURSOR" -ge 1 ] && [ "$CURSOR" -le 16 ]; then
                    eval "SEL_$CURSOR=\$((1 - SEL_$CURSOR))"
                elif [ "$CURSOR" -eq 17 ]; then
                    do_install=1
                elif [ "$CURSOR" -eq 18 ]; then
                    toggle_all
                elif [ "$CURSOR" -eq 19 ]; then
                    if has_outdated_tools; then
                        select_outdated
                    else
                        echo -e "\n${BLUE}Goodbye!${NC}"
                        exit 0
                    fi
                elif [ "$CURSOR" -eq 20 ]; then
                    echo -e "\n${BLUE}Goodbye!${NC}"
                    exit 0
                fi
                ;;
            NUM_*)
                num="${action#NUM_}"
                eval "SEL_$num=\$((1 - SEL_$num))"
                ;;
            INSTALL)
                do_install=1
                ;;
            ALL)
                toggle_all
                ;;
            OUTDATED)
                select_outdated
                ;;
            EXIT)
                echo -e "\n${BLUE}Goodbye!${NC}"
                exit 0
                ;;
        esac
    fi
    
    if [ "$do_install" -eq 1 ]; then
        do_install=0 # Reset flag
        
        # Count selected tools
        count=0
        for i in {1..16}; do
            eval "val=\$SEL_$i"
            if [ "$val" -eq 1 ]; then
                count=$((count + 1))
            fi
        done
        
        if [ "$count" -eq 0 ]; then
            echo -e "\n${YELLOW}No tools selected. Use Up/Down + Space or numbers to select.${NC}"
            echo -e "\nPress Enter to continue..."
            read -r
            continue
        fi
        
        echo -e "\n${BLUE}Preparing installation...${NC}\n"
        
        # Check confirm_reinstall upfront for tools that are already up-to-date
        if [ "$SEL_1" -eq 1 ] && [[ "$INST_BUN" == "$LATEST_BUN" ]] && ! confirm_reinstall "Bun" "$LATEST_BUN"; then
            SEL_1=0
        fi
        if [ "$SEL_2" -eq 1 ] && [[ "$INST_GO" == "$LATEST_GO" ]] && ! confirm_reinstall "Go" "$LATEST_GO"; then
            SEL_2=0
        fi
        if [ "$SEL_3" -eq 1 ] && [[ "$INST_JDK" == "$LATEST_JDK" ]] && ! confirm_reinstall "Eclipse Temurin JDK LTS" "$LATEST_JDK"; then
            SEL_3=0
        fi
        if [ "$SEL_4" -eq 1 ] && [[ "$INST_NODE" == "$LATEST_NODE" ]] && ! confirm_reinstall "Node.js" "$LATEST_NODE"; then
            SEL_4=0
        fi
        if [ "$SEL_5" -eq 1 ] && [[ -n "$INST_PYTHON" && -n "$INST_UV" ]] && ! confirm_reinstall "Python & uv" "$LATEST_PYTHON"; then
            SEL_5=0
        fi
        if [ "$SEL_6" -eq 1 ] && [[ "$INST_RUST" == "$LATEST_RUST" ]] && ! confirm_reinstall "Rust" "$LATEST_RUST"; then
            SEL_6=0
        fi
        if [ "$SEL_8" -eq 1 ] && [[ "$INST_ORB" == "$LATEST_ORB" ]] && ! confirm_reinstall "OrbStack" "$LATEST_ORB"; then
            SEL_8=0
        fi
        if [ "$SEL_9" -eq 1 ] && [[ "$INST_ANDROID_STUDIO" == "$LATEST_ANDROID_STUDIO" ]] && ! confirm_reinstall "Android Studio" "$LATEST_ANDROID_STUDIO"; then
            SEL_9=0
        fi
        if [ "$SEL_10" -eq 1 ] && [[ "$INST_VSCODE" == "$LATEST_VSCODE" ]] && ! confirm_reinstall "VSCode" "$LATEST_VSCODE"; then
            SEL_10=0
        fi
        if [ "$SEL_11" -eq 1 ] && [[ "$INST_DBEAVER" == "$LATEST_DBEAVER" ]] && ! confirm_reinstall "DBeaver Community Edition" "$LATEST_DBEAVER"; then
            SEL_11=0
        fi
        if [ "$SEL_12" -eq 1 ] && [[ "$INST_COMPASS" == "$LATEST_COMPASS" ]] && ! confirm_reinstall "MongoDB Compass" "$LATEST_COMPASS"; then
            SEL_12=0
        fi
        if [ "$SEL_13" -eq 1 ] && [[ "$INST_ANTIGRAVITY" == "$LATEST_ANTIGRAVITY" ]] && ! confirm_reinstall "Antigravity" "$LATEST_ANTIGRAVITY"; then
            SEL_13=0
        fi
        if [ "$SEL_14" -eq 1 ] && [[ "$INST_CLAUDE" == "$LATEST_CLAUDE" ]] && ! confirm_reinstall "Claude" "$LATEST_CLAUDE"; then
            SEL_14=0
        fi
        if [ "$SEL_15" -eq 1 ] && [[ "$INST_CODEX" == "$LATEST_CODEX" ]] && ! confirm_reinstall "Codex" "$LATEST_CODEX"; then
            SEL_15=0
        fi
        if [ "$SEL_16" -eq 1 ] && [[ "$INST_CHROME" == "$LATEST_CHROME" ]] && ! confirm_reinstall "Google Chrome" "$LATEST_CHROME"; then
            SEL_16=0
        fi

        # Recount after up-to-date checks
        count=0
        for i in {1..16}; do
            eval "val=\$SEL_$i"
            if [ "$val" -eq 1 ]; then
                count=$((count + 1))
            fi
        done

        if [ "$count" -eq 0 ]; then
            echo -e "\n${YELLOW}No tools to install or update.${NC}"
            echo -e "\nPress Enter to return to menu..."
            read -r
            continue
        fi

        # Check for running GUI apps among remaining selected tools
        WAS_RUNNING_ORB=0
        WAS_RUNNING_ANDROID_STUDIO=0
        WAS_RUNNING_VSCODE=0
        WAS_RUNNING_DBEAVER=0
        WAS_RUNNING_COMPASS=0
        WAS_RUNNING_ANTIGRAVITY=0
        WAS_RUNNING_CLAUDE=0
        WAS_RUNNING_CODEX=0
        WAS_RUNNING_CHROME=0

        running_app_names=()
        running_app_paths=()

        if [ "$SEL_8" -eq 1 ] && is_app_running "/Applications/OrbStack.app"; then
            running_app_names+=("OrbStack")
            running_app_paths+=("/Applications/OrbStack.app")
            WAS_RUNNING_ORB=1
        fi
        if [ "$SEL_9" -eq 1 ] && is_app_running "/Applications/Android Studio.app"; then
            running_app_names+=("Android Studio")
            running_app_paths+=("/Applications/Android Studio.app")
            WAS_RUNNING_ANDROID_STUDIO=1
        fi
        if [ "$SEL_10" -eq 1 ] && is_app_running "/Applications/Visual Studio Code.app"; then
            running_app_names+=("VSCode")
            running_app_paths+=("/Applications/Visual Studio Code.app")
            WAS_RUNNING_VSCODE=1
        fi
        if [ "$SEL_11" -eq 1 ] && is_app_running "/Applications/DBeaver.app"; then
            running_app_names+=("DBeaver")
            running_app_paths+=("/Applications/DBeaver.app")
            WAS_RUNNING_DBEAVER=1
        fi
        if [ "$SEL_12" -eq 1 ] && is_app_running "/Applications/MongoDB Compass.app"; then
            running_app_names+=("MongoDB Compass")
            running_app_paths+=("/Applications/MongoDB Compass.app")
            WAS_RUNNING_COMPASS=1
        fi
        if [ "$SEL_13" -eq 1 ] && is_app_running "/Applications/Antigravity.app"; then
            running_app_names+=("Antigravity")
            running_app_paths+=("/Applications/Antigravity.app")
            WAS_RUNNING_ANTIGRAVITY=1
        fi
        if [ "$SEL_14" -eq 1 ] && is_app_running "/Applications/Claude.app"; then
            running_app_names+=("Claude")
            running_app_paths+=("/Applications/Claude.app")
            WAS_RUNNING_CLAUDE=1
        fi
        if [ "$SEL_15" -eq 1 ] && is_app_running "/Applications/Codex.app"; then
            running_app_names+=("Codex")
            running_app_paths+=("/Applications/Codex.app")
            WAS_RUNNING_CODEX=1
        fi
        if [ "$SEL_16" -eq 1 ] && is_app_running "/Applications/Google Chrome.app"; then
            running_app_names+=("Google Chrome")
            running_app_paths+=("/Applications/Google Chrome.app")
            WAS_RUNNING_CHROME=1
        fi

        if [ ${#running_app_names[@]} -gt 0 ]; then
            echo -e "\n${YELLOW}⚠️  Warning: The following running application(s) need to be closed to proceed with update:${NC}"
            for app_n in "${running_app_names[@]}"; do
                echo -e "${YELLOW}   - ${app_n}${NC}"
            done
            echo -n -e "${YELLOW}Do you want to close them and continue? (y/N): ${NC}"
            read -r response
            if [[ ! "$response" =~ ^[Yy]$ ]]; then
                echo -e "\n${YELLOW}Installation cancelled.${NC}"
                echo -e "\nPress Enter to return to menu..."
                read -r
                continue
            fi

            # User confirmed: kill all running apps
            echo -e "${BLUE}Closing running applications...${NC}"
            for app_p in "${running_app_paths[@]}"; do
                kill_app "$app_p"
            done
        fi

        echo -e "\n${BLUE}Starting installation of $count selected tool(s)...${NC}\n"
        
        {
            echo "=================================================="
            echo "Batch installation started: $(date)"
            echo "=================================================="
            
            # 1. Bun
            if [ "$SEL_1" -eq 1 ]; then
                install_bun
                echo ""
            fi
            
            # 2. Go
            if [ "$SEL_2" -eq 1 ]; then
                install_go
                echo ""
            fi
            
            # 3. JDK (Eclipse Temurin LTS)
            if [ "$SEL_3" -eq 1 ]; then
                install_jdk
                echo ""
            fi
            
            # 4. Node.js
            if [ "$SEL_4" -eq 1 ]; then
                install_node "$LATEST_NODE"
                echo ""
            fi
            
            # 5. Python & uv
            if [ "$SEL_5" -eq 1 ]; then
                install_python
                echo ""
            fi
            
            # 6. Rust
            if [ "$SEL_6" -eq 1 ]; then
                install_rust
                echo ""
            fi
            
            # 7. Git
            if [ "$SEL_7" -eq 1 ]; then
                install_git
                echo ""
            fi
            
            # 8. OrbStack
            if [ "$SEL_8" -eq 1 ]; then
                install_orb
                echo ""
            fi
            
            # 9. Android Studio
            if [ "$SEL_9" -eq 1 ]; then
                install_android_studio
                echo ""
            fi
            
            # 10. VSCode
            if [ "$SEL_10" -eq 1 ]; then
                install_vscode
                echo ""
            fi
            
            # 11. DBeaver
            if [ "$SEL_11" -eq 1 ]; then
                install_dbeaver
                echo ""
            fi
            
            # 12. MongoDB Compass
            if [ "$SEL_12" -eq 1 ]; then
                install_compass
                echo ""
            fi
            
            # 13. Antigravity
            if [ "$SEL_13" -eq 1 ]; then
                install_antigravity
                echo ""
            fi
            
            # 14. Claude
            if [ "$SEL_14" -eq 1 ]; then
                install_claude
                echo ""
            fi
            
            # 15. Codex
            if [ "$SEL_15" -eq 1 ]; then
                install_codex
                echo ""
            fi
            
            # 16. Google Chrome
            if [ "$SEL_16" -eq 1 ]; then
                install_chrome
                echo ""
            fi
            
            echo "=================================================="
            echo "Batch installation finished: $(date)"
            echo "=================================================="
        } 2>&1 | tee -a "$LOG_FILE"
        
        # Reset selections after installation
        SEL_1=0; SEL_2=0; SEL_3=0; SEL_4=0; SEL_5=0; SEL_6=0; SEL_7=0; SEL_8=0; SEL_9=0; SEL_10=0; SEL_11=0; SEL_12=0; SEL_13=0; SEL_14=0; SEL_15=0; SEL_16=0
        
        echo -e "${GREEN}Batch installation completed!${NC}"
        echo -e "Logs saved to: ${YELLOW}${LOG_FILE}${NC}"
        echo -e "Please run ${YELLOW}source ~/.zshrc${NC} to load environment changes."
        echo -e "\nPress Enter to return to the menu..."
        read -r
        refresh_installed_tools
    fi
done
