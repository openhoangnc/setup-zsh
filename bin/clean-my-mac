#!/bin/bash

# setup-zsh clean-my-mac
# Interactive macOS cleanup for developer caches, build artifacts, temp data,
# leftover data from uninstalled apps, and regenerable folders in your code repos.
#
# What it does:
#   1. Reclaims space from regenerable caches / build output (Xcode, Go, Node,
#      Gradle, Maven, Cargo, Python, Homebrew, Electron & browser caches, ...).
#   2. Clears project junk in your repos (node_modules, dist, build, target,
#      __pycache__, or anything your .gitignore ignores).
#   3. Surfaces leftover data from apps that are no longer installed.
#
# Everything it can clean is described by JSON "rule" files (see the
# clean-my-mac-rules/ directory of the setup-zsh repo). The tool reads them from
# a local folder, or downloads them, so it also runs standalone:
#
#   curl -sSL https://raw.githubusercontent.com/openhoangnc/setup-zsh/main/bin/clean-my-mac | bash
#
# Nothing is deleted without an itemized confirmation. Caches / build output are
# removed permanently (they regenerate); orphaned app data and git-ignored files
# are moved to the Trash so they can be restored. --dry-run only looks.

set -u

# ---- Colors (only when writing to a terminal) ------------------------------
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
    RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[0;33m'
    BLUE=$'\033[0;34m'; PURPLE=$'\033[0;35m'; CYAN=$'\033[0;36m'
    BOLD=$'\033[1m'; DIM=$'\033[2m'; NC=$'\033[0m'
else
    RED=; GREEN=; YELLOW=; BLUE=; PURPLE=; CYAN=; BOLD=; DIM=; NC=
fi

# Where pattern files are fetched from when no local copy is found.
REMOTE_BASE="${CLEAN_MY_MAC_REMOTE:-https://raw.githubusercontent.com/openhoangnc/setup-zsh/main/clean-my-mac-rules}"

# ---- Options ---------------------------------------------------------------
DRY_RUN=0
ASSUME_YES=0
NON_INTERACTIVE=0
PROJECTS_ENABLED=0                          # --projects: also scan code repos
PATTERNS_SRC="${CLEAN_MY_MAC_PATTERNS:-}"   # override: a local dir or a base URL

usage() {
    cat <<EOF
${CYAN}clean-my-mac${NC} — reclaim disk from dev caches, project junk & leftover app data.

${YELLOW}Usage:${NC}
  clean-my-mac [options]
  curl -sSL <raw-url>/bin/clean-my-mac | bash            # standalone
  curl -sSL <raw-url>/bin/clean-my-mac | bash -s -- -n   # standalone, dry-run

${YELLOW}Options:${NC}
  -n, --dry-run        scan and show what could be freed, delete nothing
  -y, --yes            non-interactive: clean the pre-selected safe caches, then exit
                       (does NOT touch project folders, orphaned data, or the Trash)
  -p, --projects       scan your code repos and list junk grouped PER PROJECT,
                       so you can pick which repos to clean (node_modules, dist,
                       build, target, __pycache__, git-ignored, ...). Off by
                       default because scanning \$HOME is slow — interactive runs
                       offer it right after the cache scan, so the flag is only
                       needed for non-interactive/scripted use.
      --patterns SRC   load rule JSON from a local directory or a base URL
                       (default: the clean-my-mac-rules/ folder next to this
                        script, else ~/.zsh/setup-zsh/clean-my-mac-rules,
                        else ${REMOTE_BASE})
      --no-color       disable colored output
  -h, --help           show this help

${YELLOW}What it cleans (all described by editable JSON pattern files):${NC}
  • Developer caches & build artifacts (Xcode, Go, Node, Gradle, Cargo, ...).
  • Electron / browser / application caches.
  • Project junk in your repos, grouped per project (node_modules, dist, build,
    target, git-ignored) — pick exactly which repos to clean.
  • Leftover data from apps you have uninstalled (moved to Trash, recoverable).

${YELLOW}Safety:${NC}
  • Caches & build output regenerate — removing them costs only a re-download/build.
  • Orphaned app data and git-ignored files are moved to the Trash, never
    hard-deleted, so you can undo.
  • Nothing runs until you review an itemized plan and confirm.
  • App sandboxes and Apple/system-owned data are never touched.
EOF
}

while [ $# -gt 0 ]; do
    case "$1" in
        -n|--dry-run) DRY_RUN=1 ;;
        -y|--yes)     ASSUME_YES=1; NON_INTERACTIVE=1 ;;
        -p|--projects) PROJECTS_ENABLED=1 ;;
        --patterns)   shift; PATTERNS_SRC="${1:-}" ;;
        --patterns=*) PATTERNS_SRC="${1#*=}" ;;
        --no-color)   RED=; GREEN=; YELLOW=; BLUE=; PURPLE=; CYAN=; BOLD=; DIM=; NC=; ;;
        -h|--help)    usage; exit 0 ;;
        *) echo "${RED}Unknown option: $1${NC}"; echo; usage; exit 1 ;;
    esac
    shift
done

# ---- Preconditions ---------------------------------------------------------
if [ "$(uname -s)" != "Darwin" ]; then
    echo "${RED}Error: clean-my-mac is for macOS only.${NC}" >&2
    exit 1
fi
if [ -z "${HOME:-}" ] || [ "$HOME" = "/" ] || [ ! -d "$HOME" ]; then
    echo "${RED}Error: \$HOME is not set to a valid directory. Refusing to run.${NC}" >&2
    exit 1
fi

# Keypresses are read from fd 3, never fd 0. Under `curl … | bash` fd 0 is the
# script itself and bash is still reading the remaining lines from it, so
# redirecting fd 0 would both steal the rest of the script and break the pipe
# (curl: "Failure writing output to destination"). Probe in a subshell so a
# missing/unusable /dev/tty produces no error and no permanent redirection.
if ( exec 3< /dev/tty ) 2>/dev/null; then
    exec 3< /dev/tty
elif [ -t 0 ]; then
    exec 3<&0
else
    # No terminal at all: reads hit EOF immediately, which every caller treats
    # as "no answer" rather than consuming the piped script as keystrokes.
    exec 3< /dev/null
fi

LOG_DIR="$HOME/.zsh/setup-zsh"
mkdir -p "$LOG_DIR" 2>/dev/null || true
LOG_FILE="$LOG_DIR/clean.log"

SCAN_DIR=$(mktemp -d "${TMPDIR:-/tmp}/clean-my-mac.XXXXXX")
cleanup_on_exit() {
    printf '\033[?25h'
    [ -n "${SCAN_DIR:-}" ] && rm -rf "$SCAN_DIR" 2>/dev/null
}
trap cleanup_on_exit EXIT
trap 'exit 130' INT TERM

# ---------------------------------------------------------------------------
# Small helpers
# ---------------------------------------------------------------------------
human_kb() {
    local kb=${1:-0}
    [ -z "$kb" ] && kb=0
    if [ "$kb" -ge 1048576 ]; then awk "BEGIN{printf \"%.2f GB\", $kb/1048576}"
    elif [ "$kb" -ge 1024 ]; then awk "BEGIN{printf \"%.0f MB\", $kb/1024}"
    else echo "${kb} KB"; fi
}

# human_to_kb <size> — parse a Docker-style size ("1.8GB", "800MB", "0B",
# "500kB", "2GiB") into whole KiB. Best-effort; unknown units yield 0.
human_to_kb() {
    local s="${1:-0}" num unit
    num="${s%%[A-Za-z]*}"            # leading number ("1.8")
    unit="${s#$num}"                 # trailing unit ("GB")
    case "$num" in ''|*[!0-9.]*) echo 0; return ;; esac
    local mult
    case "$unit" in
        B|"")     mult=1 ;;
        kB|KB|kb) mult=1000 ;;       KiB|kiB) mult=1024 ;;
        MB|mb)    mult=1000000 ;;    MiB|miB) mult=1048576 ;;
        GB|gb)    mult=1000000000 ;; GiB|giB) mult=1073741824 ;;
        TB|tb)    mult=1000000000000 ;; TiB|tiB) mult=1099511627776 ;;
        *) echo 0; return ;;
    esac
    awk "BEGIN{printf \"%d\", ($num*$mult)/1024}"
}

# bounded <seconds> <cmd...> — run a command with a hard timeout (macOS has no
# timeout(1)); used so a hung/absent container daemon can't stall the scan.
bounded() {
    local secs="$1"; shift
    "$@" &
    local pid=$!
    # The watcher's fds are sent to /dev/null so that if it (or its sleep child)
    # outlives the command, it does not hold a caller's process-substitution pipe
    # open — which would block the reader until the timeout elapsed.
    ( sleep "$secs"; kill "$pid" 2>/dev/null ) >/dev/null 2>&1 &
    local watcher=$!
    wait "$pid" 2>/dev/null; local rc=$?
    kill "$watcher" 2>/dev/null; wait "$watcher" 2>/dev/null
    return $rc
}

# engine_ok <name> — allow ONLY known container CLIs, by exact name. Engine names
# come from JSON and are passed to a shell command, so this whitelist is the
# guard against command injection via a hostile/edited rules file.
engine_ok() { case "$1" in docker|podman|nerdctl) return 0 ;; *) return 1 ;; esac; }
du_kb() {
    [ -e "$1" ] || { echo 0; return; }
    du -sk "$1" 2>/dev/null | awk '{print $1}' || echo 0
}
# is_nonempty <path> — true for a regular file, or a directory holding anything.
# Uses globbing rather than $(ls -A) because this runs once per matched path and
# a rules set expands to hundreds of them: a fork each is what made scanning
# take minutes.
is_nonempty() {
    [ -f "$1" ] && return 0
    if [ -d "$1" ]; then
        local __e
        for __e in "$1"/* "$1"/.[!.]*; do
            if [ -e "$__e" ] || [ -L "$__e" ]; then return 0; fi
        done
    fi
    return 1
}
cat_indices() {
    local i=0
    while [ "$i" -lt "$N" ]; do echo "$i"; i=$((i + 1)); done
}
expand_tilde() { case "$1" in "~/"*) echo "$HOME/${1#\~/}" ;; "~") echo "$HOME" ;; *) echo "$1" ;; esac; }

# is_safe_target <path> — last line of defense before any deletion. Must be a
# non-empty, absolute, existing path with no "..", living under $HOME (the only
# place any pattern or scan can legitimately point).
# $HOME resolved through any symlinks — used for the physical containment check.
HOME_P=$(cd -P "$HOME" 2>/dev/null && pwd -P) || HOME_P="$HOME"
is_safe_target() {
    local p="$1"
    [ -n "$p" ] || return 1
    case "$p" in
        /|"$HOME"|"$HOME/"|"$HOME_P"|"$HOME_P/") return 1 ;;
        /*) : ;;
        *)  return 1 ;;
    esac
    case "$p" in *..*) return 1 ;; esac
    [ -e "$p" ] || return 1
    # Never touch high-value user data, no matter what a pattern claims.
    case "$p" in
        "$HOME"/Documents|"$HOME"/Documents/*|"$HOME"/Desktop|"$HOME"/Desktop/*|\
        "$HOME"/Downloads|"$HOME"/Downloads/*|"$HOME"/Pictures|"$HOME"/Pictures/*|\
        "$HOME"/Movies|"$HOME"/Movies/*|"$HOME"/Music|"$HOME"/Music/*|\
        "$HOME"/.ssh|"$HOME"/.ssh/*|"$HOME"/.gnupg|"$HOME"/.gnupg/*|\
        "$HOME"/Library/Mobile\ Documents|"$HOME"/Library/Mobile\ Documents/*) return 1 ;;
    esac
    # Lexical containment under $HOME.
    case "$p" in "$HOME"/*) : ;; *) return 1 ;; esac
    # Physical containment: resolve the parent so a symlinked path component
    # (e.g. an app-data dir relocated onto an external volume) cannot lead a
    # delete outside the real home tree.
    local rp
    rp=$(cd -P "$(dirname "$p")" 2>/dev/null && pwd -P) || return 1
    case "$rp/" in "$HOME_P/"|"$HOME_P"/*) return 0 ;; *) return 1 ;; esac
}

# ---------------------------------------------------------------------------
# JSON parsing (JXA — the JavaScriptCore parser shipped with every macOS; no
# jq / python required). Emits a flat line protocol whose fields are separated
# by US (\x1f, "\037"), NOT tab: US is not an IFS-whitespace character, so bash
# `read` preserves EMPTY fields (an omitted icon must not shift the columns).
# Records are newline-separated. Field layout per record type:
#   SR<US>root | SPRUNE<US>name | SDEPTH<US>n | SREPOS<US>n           (scan config)
#   C<US>kind<US>icon<US>name<US>method<US>default<US>desc            (category)
#   P<US>path | D<US>dirname                                         (paths / dirs)
#   L<US>path<US>strip | SKIP<US>prefix | SHARED<US>id                (orphan config)
#   FILE<US>name | ORPHAN<US>name | ERR<US>message
# ---------------------------------------------------------------------------
parse_json_file() {
    osascript -l JavaScript - "$1" <<'JXA'
function run(argv) {
  ObjC.import('Foundation');
  var ns = $.NSString.stringWithContentsOfFileEncodingError($(argv[0]), $.NSUTF8StringEncoding, null);
  if (!ns || (ns.isNil && ns.isNil())) { return 'ERR\x1fcould not read file'; }
  var o;
  try { o = JSON.parse(ns.js); } catch (e) { return 'ERR\x1f' + e.message; }
  var out = [];
  function tab() { return Array.prototype.slice.call(arguments).join('\x1f'); }
  if (o.scan) {
    (o.scan.roots  || []).forEach(function(r){ out.push(tab('SR', r)); });
    (o.scan.prune  || []).forEach(function(p){ out.push(tab('SPRUNE', p)); });
    if (o.scan.maxDepth != null) out.push(tab('SDEPTH', o.scan.maxDepth));
    if (o.scan.maxRepos != null) out.push(tab('SREPOS', o.scan.maxRepos));
  }
  (o.categories || []).forEach(function(c){
    out.push(tab('C', c.kind || 'paths', c.icon || '', c.name || '', c.method || 'rm', c['default'] ? 1 : 0, c.desc || ''));
    (c.paths   || []).forEach(function(p){ out.push(tab('P', p)); });
    (c.dirs    || []).forEach(function(d){ out.push(tab('D', d)); });
    (c.engines || []).forEach(function(e){ out.push(tab('E', e)); });
  });
  (o.patternFiles    || []).forEach(function(f){ out.push(tab('FILE', f)); });
  if (o.orphanConfig) out.push(tab('ORPHAN', o.orphanConfig));
  (o.locations       || []).forEach(function(l){ out.push(tab('L', l.path || '', l.strip || '')); });
  (o.skipPrefixes    || []).forEach(function(p){ out.push(tab('SKIP', p)); });
  (o.sharedComponents|| []).forEach(function(p){ out.push(tab('SHARED', p)); });
  return out.join('\n');
}
JXA
}

# ---------------------------------------------------------------------------
# Category model (parallel indexed arrays — bash 3.2, no associative arrays)
# ---------------------------------------------------------------------------
CAT_ICON=(); CAT_NAME=(); CAT_DESC=(); CAT_METHOD=()
CAT_DEFAULT=(); CAT_PATHS=(); CAT_KB=(); CAT_SEL=(); N=0
# CAT_PMETHOD: for method="project" categories, a newline-separated list of
# per-path methods aligned line-for-line with CAT_PATHS (a repo mixes rm'd
# build dirs with trashed git-ignored config). Empty for every other category.
# CAT_SUMMARY: a short "what's inside" blurb shown after the size in the menu.
CAT_PMETHOD=(); CAT_SUMMARY=()

# Project-scan config + pending project/gitignore categories (filled by JSON).
SCAN_ROOTS=(); SCAN_PRUNE=(); SCAN_DEPTH=8; SCAN_MAXREPOS=400
PROJ_ICON=(); PROJ_NAME=(); PROJ_METHOD=(); PROJ_DEFAULT=(); PROJ_DESC=(); PROJ_DIRS=(); PROJ_N=0
GI_ICON=""; GI_NAME=""; GI_METHOD="trash"; GI_DEFAULT=0; GI_DESC=""; GI_ON=0
# Pending container (docker/podman) categories (filled by JSON).
CONT_ICON=(); CONT_NAME=(); CONT_METHOD=(); CONT_DEFAULT=(); CONT_DESC=(); CONT_ENGINES=(); CONT_N=0

# Orphan-detection config.
ORPH_LOC_PATH=(); ORPH_LOC_STRIP=(); SKIP_PREFIXES=(); SHARED_COMPONENTS=()

add_category() { # icon name desc method default paths [pmethods]
    CAT_ICON[$N]="$1"; CAT_NAME[$N]="$2"; CAT_DESC[$N]="$3"
    CAT_METHOD[$N]="$4"; CAT_DEFAULT[$N]="$5"; CAT_PATHS[$N]="$6"
    CAT_PMETHOD[$N]="${7:-}"; CAT_SUMMARY[$N]=""
    CAT_SEL[$N]="$5"; CAT_KB[$N]=0; N=$((N + 1))
}

# register_paths — expand a newline-separated path list (~ and * globs) into the
# concrete, existing, non-empty, de-duplicated paths, then add the category.
register_paths() {
    local icon="$1" name="$2" method="$3" default="$4" desc="$5" pathlist="$6"
    local found="" pat m
    while IFS= read -r pat; do
        [ -n "$pat" ] || continue
        pat=$(expand_tilde "$pat")
        # Expand the pattern with bash's own pathname expansion instead of
        # `< <(compgen -G "$pat")`. The process substitution cost a fork per
        # pattern, and a full rules set is ~250 of them: past roughly 250
        # bash 3.2 stops making progress entirely and the scan hangs for
        # minutes instead of finishing in seconds.
        #
        # IFS is emptied so the unquoted $pat still globs but does NOT
        # word-split — patterns like "~/Library/Application Support/*/Code
        # Cache" contain spaces, and splitting them matches nothing at all.
        # An unmatched glob expands to itself, which the -e test discards.
        local __ifs="$IFS"; IFS=
        for m in $pat; do
            IFS="$__ifs"
            [ -e "$m" ] || { IFS=; continue; }
            is_nonempty "$m" || { IFS=; continue; }
            case "
$found
" in *"
$m
"*) IFS=; continue ;; esac
            found="${found:+$found
}$m"
            IFS=
        done
        IFS="$__ifs"
    done <<EOF
$pathlist
EOF
    [ -n "$found" ] && add_category "$icon" "$name" "$desc" "$method" "$default" "$found"
}

# ---------------------------------------------------------------------------
# Pattern loading
# ---------------------------------------------------------------------------
PATTERNS_DIR=""   # resolved local directory that holds the JSON files

# fetch <url-or-path> <dest> — copy a local file or download a remote one.
fetch() {
    local src="$1" dest="$2"
    case "$src" in
        http://*|https://*) curl -fsSL --max-time 20 "$src" -o "$dest" 2>/dev/null ;;
        *) [ -f "$src" ] && cp "$src" "$dest" 2>/dev/null ;;
    esac
}

# resolve_patterns — decide where pattern JSON comes from and stage a local copy
# of index.json + every listed file into $SCAN_DIR/patterns. Sets PATTERNS_DIR.
resolve_patterns() {
    local staged="$SCAN_DIR/patterns"
    mkdir -p "$staged"

    # 1) Locate a source of index.json: explicit --patterns, a clean-my-mac-rules/
    #    folder next to this script, ~/.zsh/setup-zsh/clean-my-mac-rules, or remote.
    local base=""
    if [ -n "$PATTERNS_SRC" ]; then
        base="$PATTERNS_SRC"
    else
        local self_dir=""
        case "${BASH_SOURCE:-}" in
            */*) self_dir=$(cd "$(dirname "${BASH_SOURCE}")" 2>/dev/null && pwd) ;;
        esac
        if [ -n "$self_dir" ] && [ -f "$self_dir/../clean-my-mac-rules/index.json" ]; then
            base=$(cd "$self_dir/../clean-my-mac-rules" && pwd)
        elif [ -f "$HOME/.zsh/setup-zsh/clean-my-mac-rules/index.json" ]; then
            base="$HOME/.zsh/setup-zsh/clean-my-mac-rules"
        else
            base="$REMOTE_BASE"
        fi
    fi

    # 2) Stage index.json.
    if ! fetch "$base/index.json" "$staged/index.json"; then
        echo "${RED}Error: could not load pattern index from:${NC} $base/index.json" >&2
        echo "${DIM}Pass --patterns <dir-or-url>, or check your network connection.${NC}" >&2
        return 1
    fi

    # 3) Stage every pattern file + the orphan config listed in the index.
    #    (Parse via the shared helper into a temp file — a heredoc nested inside
    #     a <(...) process substitution mis-parses, so we avoid that form.)
    parse_json_file "$staged/index.json" > "$SCAN_DIR/index.tsv" 2>/dev/null
    if grep -q "^ERR$(printf '\037')" "$SCAN_DIR/index.tsv"; then
        echo "${RED}Error: pattern index ($base/index.json) is not valid JSON.${NC}" >&2
        return 1
    fi
    PATTERNS_DIR="$staged"
    ORPHAN_CONFIG_FILE=""
    ORPHAN_CONFIG_BASENAME=""
    local typ val staged_files=0
    while IFS=$'\x1f' read -r typ val _; do
        case "$typ" in
            FILE)
                if fetch "$base/$val" "$staged/$val"; then staged_files=$((staged_files + 1))
                else echo "${YELLOW}Warning: could not load pattern file $val${NC}" >&2; fi ;;
            ORPHAN)
                if fetch "$base/$val" "$staged/$val"; then
                    ORPHAN_CONFIG_FILE="$staged/$val"; ORPHAN_CONFIG_BASENAME="$val"
                else echo "${YELLOW}Warning: could not load orphan config $val${NC}" >&2; fi ;;
        esac
    done < "$SCAN_DIR/index.tsv"

    if [ "$staged_files" -eq 0 ]; then
        echo "${RED}Error: no pattern files could be loaded from:${NC} $base" >&2
        echo "${DIM}Pass --patterns <dir-or-url>, or check your network connection.${NC}" >&2
        return 1
    fi
    return 0
}

# load_patterns — parse each staged pattern file into path/project/gitignore
# categories + scan config, and the orphan config into its arrays.
load_patterns() {
    # Reset everything this rebuilds.
    CAT_ICON=(); CAT_NAME=(); CAT_DESC=(); CAT_METHOD=()
    CAT_DEFAULT=(); CAT_PATHS=(); CAT_KB=(); CAT_SEL=(); N=0
    CAT_PMETHOD=(); CAT_SUMMARY=()
    SCAN_ROOTS=(); SCAN_PRUNE=(); SCAN_DEPTH=8; SCAN_MAXREPOS=400
    PROJ_ICON=(); PROJ_NAME=(); PROJ_METHOD=(); PROJ_DEFAULT=(); PROJ_DESC=(); PROJ_DIRS=(); PROJ_N=0
    GI_ON=0; GI_ICON=""; GI_NAME=""; GI_METHOD="trash"; GI_DEFAULT=0; GI_DESC=""
    CONT_ICON=(); CONT_NAME=(); CONT_METHOD=(); CONT_DEFAULT=(); CONT_DESC=(); CONT_ENGINES=(); CONT_N=0
    ORPH_LOC_PATH=(); ORPH_LOC_STRIP=(); SKIP_PREFIXES=(); SHARED_COMPONENTS=()
    PARSED_OK=0

    # Pattern files are every staged *.json except index.json and the exact
    # orphan-config file named by the index.
    local f base
    for f in "$PATTERNS_DIR"/*.json; do
        [ -f "$f" ] || continue
        base="${f##*/}"
        [ "$base" = "index.json" ] && continue
        [ -n "${ORPHAN_CONFIG_BASENAME:-}" ] && [ "$base" = "$ORPHAN_CONFIG_BASENAME" ] && continue
        parse_pattern_stream "$f"
    done

    # Orphan config (optional).
    [ -n "${ORPHAN_CONFIG_FILE:-}" ] && [ -f "$ORPHAN_CONFIG_FILE" ] && parse_orphan_stream "$ORPHAN_CONFIG_FILE"
}

# flush_pattern_category — emit the currently-accumulated category (helper for
# parse_pattern_stream; uses that function's locals via dynamic scope).
flush_pattern_category() {
    [ "$have" -eq 1 ] || return 0
    case "$ckind" in
        project)
            PROJ_ICON[$PROJ_N]="$cicon"; PROJ_NAME[$PROJ_N]="$cname"
            PROJ_METHOD[$PROJ_N]="$cmethod"; PROJ_DEFAULT[$PROJ_N]="$cdefault"
            PROJ_DESC[$PROJ_N]="$cdesc"; PROJ_DIRS[$PROJ_N]="$cdirs"; PROJ_N=$((PROJ_N + 1)) ;;
        gitignore)
            GI_ON=1; GI_ICON="$cicon"; GI_NAME="$cname"; GI_METHOD="$cmethod"
            GI_DEFAULT="$cdefault"; GI_DESC="$cdesc" ;;
        container)
            CONT_ICON[$CONT_N]="$cicon"; CONT_NAME[$CONT_N]="$cname"
            CONT_METHOD[$CONT_N]="$cmethod"; CONT_DEFAULT[$CONT_N]="$cdefault"
            CONT_DESC[$CONT_N]="$cdesc"; CONT_ENGINES[$CONT_N]="$cengines"; CONT_N=$((CONT_N + 1)) ;;
        *)
            register_paths "$cicon" "$cname" "$cmethod" "$cdefault" "$cdesc" "$cpaths" ;;
    esac
}

# parse_pattern_stream <file> — consume the JXA line protocol for one pattern
# file, registering path categories immediately and queuing project/gitignore
# categories (filled later by scan_projects). Lines are read raw (not field-
# split) because the C header line carries 6 tab-separated fields of its own.
parse_pattern_stream() {
    local file="$1"
    local ckind="" cicon="" cname="" cmethod="" cdefault="" cdesc="" cpaths="" cdirs="" cengines="" have=0
    local line typ rest us=$'\x1f'
    while IFS= read -r line; do
        typ="${line%%$us*}"       # text before the first US separator
        rest="${line#*$us}"       # text after the first US separator
        case "$typ" in
            ERR) echo "${YELLOW}Warning: skipping invalid pattern file ${file##*/}: $rest${NC}" >&2; return 0 ;;
            SR) SCAN_ROOTS[${#SCAN_ROOTS[@]}]="$rest" ;;
            SPRUNE) SCAN_PRUNE[${#SCAN_PRUNE[@]}]="$rest" ;;
            SDEPTH) SCAN_DEPTH="$rest" ;;
            SREPOS) SCAN_MAXREPOS="$rest" ;;
            C)
                flush_pattern_category
                IFS=$us read -r ckind cicon cname cmethod cdefault cdesc <<EOF
$rest
EOF
                have=1; cpaths=""; cdirs=""; cengines="" ;;
            P) cpaths="${cpaths:+$cpaths
}$rest" ;;
            D) cdirs="${cdirs:+$cdirs
}$rest" ;;
            E) cengines="${cengines:+$cengines
}$rest" ;;
        esac
    done < <(parse_json_file "$file")
    flush_pattern_category
    PARSED_OK=$((PARSED_OK + 1))
}

# parse_orphan_stream <file>
parse_orphan_stream() {
    local typ a b us=$'\x1f'
    while IFS="$us" read -r typ a b; do
        case "$typ" in
            L) ORPH_LOC_PATH[${#ORPH_LOC_PATH[@]}]="$a"; ORPH_LOC_STRIP[${#ORPH_LOC_STRIP[@]}]="$b" ;;
            SKIP) SKIP_PREFIXES[${#SKIP_PREFIXES[@]}]="$a" ;;
            SHARED) SHARED_COMPONENTS[${#SHARED_COMPONENTS[@]}]="$a" ;;
        esac
    done < <(parse_json_file "$1")
}

# ---------------------------------------------------------------------------
# Project-junk scanning (node_modules, dist, build, target, git-ignored, ...)
#
# Junk is grouped BY PROJECT — one category per git repository — so you can pick
# exactly which projects to clean and see what each holds. Junk that isn't inside
# a repo is skipped (it's almost always a tool/language cache the cache rules
# already cover, not one of your projects). Within a project every item keeps its
# own method: known regenerable build/dependency dirs are deleted (they rebuild),
# while any other git-ignored entry (local .env, config, logs) is moved to the
# Trash so it can be recovered.
#
# The helpers below (classify_method / project_key / shorten_left /
# flush_project_category) are only ever called from scan_projects and read its
# locals through bash dynamic scope — the same pattern parse_pattern_stream and
# flush_pattern_category use.
# ---------------------------------------------------------------------------

# classify_method <basename> — echo the method a known regenerable dir name maps
# to (from the JSON project categories), or empty if the name is not a known
# build/dependency dir. Reads scan_projects' KN[]/KM[] aligned arrays.
classify_method() {
    local bn="$1" j=0
    while [ "$j" -lt "${#KN[@]}" ]; do
        [ "${KN[$j]}" = "$bn" ] && { printf '%s' "${KM[$j]}"; return; }
        j=$((j + 1))
    done
    printf ''
}

# project_key <path> — echo the nearest enclosing git repo root (longest match
# wins; REPO_ROOTS is sorted longest first), or EMPTY when the path is not inside
# any repo. A "project" is a git repo: junk that isn't in one is almost always a
# tool/language cache (Go stdlib, global npm, cargo/npx cache, editor
# extensions), which the cache categories already handle and which must not be
# swept up here — so callers skip a path with no key.
project_key() {
    local path="$1" j=0 r
    while [ "$j" -lt "${#REPO_ROOTS[@]}" ]; do
        r="${REPO_ROOTS[$j]}"; j=$((j + 1))
        case "$path" in "$r"|"$r"/*) printf '%s' "$r"; return ;; esac
    done
    printf ''
}

# shorten_left <str> <max> — clip an over-long path from the LEFT (keep the tail,
# which names the project) so the menu row stays aligned.
shorten_left() {
    local s="$1" max="$2"
    if [ "${#s}" -le "$max" ]; then printf '%s' "$s"
    else printf '…%s' "${s: -$((max - 1))}"; fi
}

# flush_project_category <key> <paths> <pmethods> <basenames> — register one
# per-project category from the accumulated newline-separated lists.
flush_project_category() {
    local key="$1" paths="$2" pmethods="$3" names="$4"
    local rel="${key/#$HOME/~}"
    local disp; disp=$(shorten_left "$rel" 36)
    # "what's inside": the full list of unique item names, joined — the menu row
    # clips it to whatever width the terminal has, so wide terminals show more.
    local summary
    summary=$(printf '%s\n' "$names" | grep -v '^$' | sort -u | awk '
        { s = s (NR > 1 ? ", " : "") $0 } END { print s }')
    add_category "📁" "$disp" \
        "Project junk in ${rel}: ${summary}. Regenerable build/dependency dirs are deleted; other git-ignored items (e.g. local .env/config) go to the Trash (recoverable)." \
        "project" 0 "$paths" "$pmethods"
    CAT_SUMMARY[$((N - 1))]="$summary"
}

scan_projects() {
    [ "$PROJECTS_ENABLED" -eq 1 ] || return 0
    { [ "$PROJ_N" -gt 0 ] || [ "$GI_ON" -eq 1 ]; } || return 0
    [ "${#SCAN_ROOTS[@]}" -gt 0 ] || return 0

    # Sanitize numeric scan config — JSON may carry non-numeric values.
    case "$SCAN_DEPTH" in ''|*[!0-9]*) SCAN_DEPTH=6 ;; esac
    case "$SCAN_MAXREPOS" in ''|*[!0-9]*) SCAN_MAXREPOS=400 ;; esac

    # Known regenerable dir names + the method each maps to (KN[i] <-> KM[i]).
    # Names with a find glob metachar (* ? [) are skipped for safety.
    local KN=() KM=() i d
    i=0
    while [ "$i" -lt "$PROJ_N" ]; do
        while IFS= read -r d; do
            [ -n "$d" ] || continue
            case "$d" in *[\*\?\[]*) continue ;; esac
            KN[${#KN[@]}]="$d"; KM[${#KM[@]}]="${PROJ_METHOD[$i]}"
        done <<EOF
${PROJ_DIRS[$i]}
EOF
        i=$((i + 1))
    done
    local uniq_names
    uniq_names=$(printf '%s\n' "${KN[@]+"${KN[@]}"}" | grep -v '^$' | sort -u)

    # One find pass per root captures BOTH repo roots (a .git DIRECTORY — needed
    # to group junk by project even when git-ignored scanning is off) AND
    # regenerable target dirs, while pruning heavy/irrelevant trees. Only a real
    # .git folder counts as a project root: a bare ".git" file (git worktrees /
    # submodules) is intentionally ignored, so a folder is a "project" only when
    # it directly contains a .git directory. .git is captured in its own branch
    # (not the prune list) so we learn the repo but never descend it.
    local name_expr="" prune_expr="" first
    first=1
    while IFS= read -r d; do
        [ -n "$d" ] || continue
        if [ "$first" -eq 1 ]; then name_expr="-name $(printf '%q' "$d")"; first=0
        else name_expr="$name_expr -o -name $(printf '%q' "$d")"; fi
    done <<EOF
$uniq_names
EOF
    first=1
    for d in ${SCAN_PRUNE[@]+"${SCAN_PRUNE[@]}"}; do
        [ "$d" = ".git" ] && continue
        if [ "$first" -eq 1 ]; then prune_expr="-name $(printf '%q' "$d")"; first=0
        else prune_expr="$prune_expr -o -name $(printf '%q' "$d")"; fi
    done
    local find_expr='\( -type d -name .git -prune -print \)'
    [ -n "$prune_expr" ] && find_expr="$find_expr -o \\( \\( $prune_expr \\) -prune \\)"
    [ -n "$name_expr" ]  && find_expr="$find_expr -o \\( -type d \\( $name_expr \\) -prune -print \\)"

    local raw="$SCAN_DIR/proj_raw"; : > "$raw"
    local root rexp
    for root in "${SCAN_ROOTS[@]}"; do
        rexp=$(expand_tilde "$root")
        [ -d "$rexp" ] || continue
        eval "find \"\$rexp\" -maxdepth \"\$SCAN_DEPTH\" $find_expr" 2>/dev/null >> "$raw"
    done

    # Split the find output into repo roots and name-matched junk dirs. The home
    # dir itself and top-level personal dirs are never treated as repos (else the
    # whole tree's ignored data would be swept into one giant "project").
    local repos_file="$SCAN_DIR/proj_repos" junk_file="$SCAN_DIR/proj_junk"
    : > "$repos_file"; : > "$junk_file"
    local line bn repo
    while IFS= read -r line; do
        [ -n "$line" ] || continue
        bn="${line##*/}"
        if [ "$bn" = ".git" ]; then
            repo="${line%/.git}"
            [ "$repo" = "$line" ] && repo=$(dirname "$line")
            case "$repo" in
                "$HOME"|"$HOME_P"|"$HOME"/Documents|"$HOME"/Desktop|"$HOME"/Downloads|\
                "$HOME"/Pictures|"$HOME"/Movies|"$HOME"/Music) continue ;;
            esac
            printf '%s\n' "$repo" >> "$repos_file"
        else
            printf '%s\n' "$line" >> "$junk_file"
        fi
    done < "$raw"

    # Repo roots sorted longest-first so project_key picks the nearest enclosing
    # repo, de-duplicated. Loaded into REPO_ROOTS for project_key (dynamic scope).
    local REPO_ROOTS=()
    while IFS= read -r line; do
        [ -n "$line" ] && REPO_ROOTS[${#REPO_ROOTS[@]}]="$line"
    done < <(awk '{ print length, $0 }' "$repos_file" 2>/dev/null | sort -rn | cut -d' ' -f2- | awk '!seen[$0]++')

    # Build (project-key US method US path) triples for every junk item. Fields
    # are US-separated (\x1f) — not a path character — so paths with spaces are
    # safe. git ls-files -z is NUL-delimited so its output needs no quoting.
    local us=$'\x1f' pairs="$SCAN_DIR/proj_pairs"; : > "$pairs"
    local p m key
    # a) Name-matched regenerable dirs — only those inside a git repo (skip
    #    tool/language caches that merely contain a dir with a matching name).
    while IFS= read -r p; do
        [ -n "$p" ] || continue
        key=$(project_key "$p"); [ -n "$key" ] || continue
        bn="${p##*/}"; m=$(classify_method "$bn"); [ -n "$m" ] || m="rm"
        printf '%s%s%s%s%s\n' "$key" "$us" "$m" "$us" "$p" >> "$pairs"
    done < "$junk_file"
    # b) Git-ignored entries, tied to the repo they came from.
    if [ "$GI_ON" -eq 1 ] && [ "${#REPO_ROOTS[@]}" -gt 0 ]; then
        local count=0 rel ri=0
        while [ "$ri" -lt "${#REPO_ROOTS[@]}" ]; do
            repo="${REPO_ROOTS[$ri]}"; ri=$((ri + 1))
            [ "$count" -ge "$SCAN_MAXREPOS" ] && break
            count=$((count + 1))
            while IFS= read -r -d '' rel; do
                rel="${rel%/}"
                [ -n "$rel" ] || continue
                p="$repo/$rel"; bn="${p##*/}"
                m=$(classify_method "$bn"); [ -n "$m" ] || m="$GI_METHOD"
                printf '%s%s%s%s%s\n' "$repo" "$us" "$m" "$us" "$p" >> "$pairs"
            done < <(cd "$repo" 2>/dev/null && git -c core.quotePath=false ls-files -z --others --ignored --exclude-standard --directory 2>/dev/null)
        done
    fi
    [ -s "$pairs" ] || return 0

    # De-duplicate and drop any item nested under another kept item (a git-ignored
    # file inside a dir we already delete) — sorting by path puts an ancestor
    # immediately before its descendants, so a single prefix test suffices; this
    # also keeps the per-project size total from double-counting. Then group by
    # project key for stable, contiguous per-project categories.
    local sorted="$SCAN_DIR/proj_sorted"
    LC_ALL=C sort -t "$us" -k3 "$pairs" \
        | awk -F "$us" '{ if ($3==kept || (kept!="" && substr($3,1,length(kept)+1)==kept"/")) next; print; kept=$3 }' \
        | LC_ALL=C sort -t "$us" -k1,1 -s > "$sorted"

    local curkey="" cpaths="" cmethods="" cnames="" k
    while IFS="$us" read -r k m p; do
        [ -n "$p" ] || continue
        if [ -n "$curkey" ] && [ "$k" != "$curkey" ]; then
            flush_project_category "$curkey" "$cpaths" "$cmethods" "$cnames"
            cpaths=""; cmethods=""; cnames=""
        fi
        curkey="$k"
        cpaths="${cpaths:+$cpaths
}$p"
        cmethods="${cmethods:+$cmethods
}$m"
        cnames="${cnames:+$cnames
}${p##*/}"
    done < "$sorted"
    [ -n "$curkey" ] && flush_project_category "$curkey" "$cpaths" "$cmethods" "$cnames"
}

# ---------------------------------------------------------------------------
# Container-engine cleanup (docker / podman / nerdctl)
# ---------------------------------------------------------------------------

# container_reclaimable_kb <engine> — KiB reclaimable by 'system prune -af'
# (images + stopped containers + build cache; volumes are deliberately excluded).
# Returns 0 if the engine's daemon is unreachable.
container_reclaimable_kb() {
    local eng="$1" typ rec total=0 kb
    while IFS='|' read -r typ rec; do
        case "$typ" in
            Images|Containers|"Build Cache")
                rec="${rec%% *}"                 # "1.8GB (72%)" -> "1.8GB"
                kb=$(human_to_kb "$rec")
                total=$((total + kb)) ;;
        esac
    done < <(bounded 8 "$eng" system df --format '{{.Type}}|{{.Reclaimable}}' 2>/dev/null)
    echo "$total"
}

# scan_containers — for each container category, register it if at least one of
# its (whitelisted, installed, running) engines reports reclaimable data. The
# category's paths are the engine names; its size is pre-computed here and
# preserved by compute_sizes (there is nothing on disk to 'du').
scan_containers() {
    [ "$CONT_N" -gt 0 ] || return 0
    local i eng avail total size
    i=0
    while [ "$i" -lt "$CONT_N" ]; do
        avail=""; total=0
        while IFS= read -r eng; do
            [ -n "$eng" ] || continue
            engine_ok "$eng" || continue
            command -v "$eng" >/dev/null 2>&1 || continue
            size=$(container_reclaimable_kb "$eng")
            [ "${size:-0}" -gt 0 ] || continue
            avail="${avail:+$avail
}$eng"
            total=$((total + size))
        done <<EOF
${CONT_ENGINES[$i]}
EOF
        if [ -n "$avail" ] && [ "$total" -gt 0 ]; then
            add_category "${CONT_ICON[$i]}" "${CONT_NAME[$i]}" "${CONT_DESC[$i]}" \
                "container" "${CONT_DEFAULT[$i]}" "$avail"
            CAT_KB[$((N - 1))]="$total"
        fi
        i=$((i + 1))
    done
}

# run_container_prune <engine-list> — run the FIXED prune command for each
# whitelisted engine. The command is hard-coded (never taken from JSON), and
# volumes are never pruned, so named volumes / databases are safe.
run_container_prune() {
    local eng
    while IFS= read -r eng; do
        [ -n "$eng" ] || continue
        if ! engine_ok "$eng"; then echo "${YELLOW}  skip (unknown engine): ${eng}${NC}"; continue; fi
        echo "${DIM}  \$ ${eng} system prune -af${NC}"
        "$eng" system prune -af 2>&1 | sed 's/^/    /'
    done <<EOF
$1
EOF
}

# ---------------------------------------------------------------------------
# Orphaned-app-data detection
# ---------------------------------------------------------------------------
INSTALLED="$SCAN_DIR/installed.txt"

build_installed_set() {
    local lsr="/System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister"
    (
        [ -x "$lsr" ] && "$lsr" -dump 2>/dev/null \
            | grep -oE '[A-Za-z][A-Za-z0-9-]*(\.[A-Za-z0-9_-]+){2,}'
    ) > "$SCAN_DIR/inst_lsr" 2>/dev/null &
    (
        mdfind 'kMDItemContentType==com.apple.application-bundle' 2>/dev/null | while IFS= read -r app; do
            defaults read "$app/Contents/Info" CFBundleIdentifier 2>/dev/null
        done
        local d
        for d in /Applications "$HOME/Applications" /System/Applications \
                 /System/Applications/Utilities /Library/PreferencePanes \
                 "$HOME/Library/PreferencePanes"; do
            [ -d "$d" ] || continue
            find "$d" -maxdepth 2 \( -name '*.app' -o -name '*.prefPane' -o -name '*.appex' \) 2>/dev/null \
                | while IFS= read -r app; do
                    defaults read "$app/Contents/Info" CFBundleIdentifier 2>/dev/null
                done
        done
        local pdir pl
        for pdir in "$HOME/Library/LaunchAgents" /Library/LaunchAgents /Library/LaunchDaemons; do
            [ -d "$pdir" ] || continue
            for pl in "$pdir"/*.plist; do
                [ -f "$pl" ] || continue
                defaults read "${pl%.plist}" Label 2>/dev/null
            done
        done
    ) > "$SCAN_DIR/inst_scan" 2>/dev/null &
    wait
    cat "$SCAN_DIR/inst_lsr" "$SCAN_DIR/inst_scan" 2>/dev/null | grep -v '^$' | sort -u > "$INSTALLED"
}

bid_is_kept() {
    local bid="$1" p
    for p in ${SKIP_PREFIXES[@]+"${SKIP_PREFIXES[@]}"}; do
        case "$bid" in "$p"*) return 0 ;; esac
    done
    for p in ${SHARED_COMPONENTS[@]+"${SHARED_COMPONENTS[@]}"}; do
        case "$bid" in "$p"*) return 0 ;; esac
    done
    # Exact match — this bundle id is installed.
    grep -qxF "$bid" "$INSTALLED" && return 0
    # Child match: is any ANCESTOR namespace of this id installed? (a sub-bundle
    # like com.foo.app.ShipIt of the live com.foo.app). Check each ancestor by
    # exact lookup — a handful of greps, not a scan of the whole install set.
    local anc="$bid"
    while case "$anc" in *.*) true ;; *) false ;; esac; do
        anc="${anc%.*}"
        grep -qxF "$anc" "$INSTALLED" && return 0
    done
    # Parent match: is any installed id a CHILD of this id? (a shared parent
    # namespace com.foo.suite while com.foo.suite.helper is installed.)
    grep -qE "^${bid//./\\.}\." "$INSTALLED" && return 0
    return 1
}

looks_like_bundle_id() {
    case "$1" in *.*.*) : ;; *) return 1 ;; esac
    case "$1" in *[!A-Za-z0-9._-]*) return 1 ;; esac
    return 0
}

# register_orphans — scan the configured locations for leftover reverse-DNS
# folders and add one category per orphaned bundle id (all paths grouped).
register_orphans() {
    [ "${#ORPH_LOC_PATH[@]}" -gt 0 ] || return 0
    local raw="$SCAN_DIR/orphans_raw.txt"
    : > "$raw"
    local li
    li=0
    while [ "$li" -lt "${#ORPH_LOC_PATH[@]}" ]; do
        local dir sfx entry name bid
        dir=$(expand_tilde "${ORPH_LOC_PATH[$li]}")
        sfx="${ORPH_LOC_STRIP[$li]}"
        li=$((li + 1))
        [ -d "$dir" ] || continue
        for entry in "$dir"/*; do
            [ -e "$entry" ] || continue
            name="${entry##*/}"
            bid="$name"
            [ -n "$sfx" ] && bid="${name%$sfx}"
            looks_like_bundle_id "$bid" || continue
            bid_is_kept "$bid" && continue
            is_nonempty "$entry" || continue
            printf '%s\t%s\n' "$bid" "$entry" >> "$raw"
        done
    done
    [ -s "$raw" ] || return 0
    local bid
    for bid in $(cut -f1 "$raw" | sort -u); do
        local paths="" rb rp
        while IFS=$'\t' read -r rb rp; do
            [ "$rb" = "$bid" ] && paths="${paths:+$paths
}$rp"
        done < "$raw"
        add_category "👻" "Orphaned: $bid" \
            "Leftover data — no installed app owns '$bid'. Moved to Trash (recoverable)." \
            "trash" 0 "$paths"
    done
}

# build_categories — assemble the whole list (re-run after a cleanup).
build_categories() {
    load_patterns
    scan_projects
    scan_containers
    register_orphans
}

# ---------------------------------------------------------------------------
# Sizing
# ---------------------------------------------------------------------------
compute_sizes_write() {
    local i
    for i in $(cat_indices); do
        (
            # Container categories carry a pre-computed size (their "paths" are
            # engine names, not files) — preserve it instead of du'ing.
            if [ "${CAT_METHOD[$i]}" = "container" ]; then
                echo "${CAT_KB[$i]}" > "$SCAN_DIR/size_$i"
            else
                local total=0 p kb
                while IFS= read -r p; do
                    [ -n "$p" ] || continue
                    kb=$(du_kb "$p"); total=$((total + kb))
                done <<EOF
${CAT_PATHS[$i]}
EOF
                echo "$total" > "$SCAN_DIR/size_$i"
            fi
        ) &
        # Size categories concurrently; cap only to avoid a runaway process count.
        if [ $(( (i + 1) % 24 )) -eq 0 ]; then wait; fi
    done
    wait
}
compute_sizes_read() {
    local i
    for i in $(cat_indices); do CAT_KB[$i]=$(cat "$SCAN_DIR/size_$i" 2>/dev/null || echo 0); done
}
compute_sizes() {
    compute_sizes_write &
    spinner_scan $! "Measuring reclaimable space..."
    wait
    compute_sizes_read
}
prune_zero() {
    local r=0 w=0
    while [ "$r" -lt "$N" ]; do
        if [ "${CAT_KB[$r]}" -gt 0 ] || [ "${CAT_METHOD[$r]}" = "emptytrash" ]; then
            if [ "$w" -ne "$r" ]; then
                CAT_ICON[$w]="${CAT_ICON[$r]}";     CAT_NAME[$w]="${CAT_NAME[$r]}"
                CAT_DESC[$w]="${CAT_DESC[$r]}";     CAT_METHOD[$w]="${CAT_METHOD[$r]}"
                CAT_DEFAULT[$w]="${CAT_DEFAULT[$r]}"; CAT_PATHS[$w]="${CAT_PATHS[$r]}"
                CAT_KB[$w]="${CAT_KB[$r]}";         CAT_SEL[$w]="${CAT_SEL[$r]}"
                CAT_PMETHOD[$w]="${CAT_PMETHOD[$r]}"; CAT_SUMMARY[$w]="${CAT_SUMMARY[$r]}"
            fi
            w=$((w + 1))
        fi
        r=$((r + 1))
    done
    N=$w
}

# sort_by_size — order the menu biggest-first, so the rows worth the most disk
# are the ones you land on. Sorts an index list through `sort` rather than in
# the shell: bash 3.2 (what macOS ships) has no associative arrays, and the
# ties matter — `sort -s` keeps equal-sized rows in their rules-file order, so
# the grouping the JSON authors chose survives.
# Must run after compute_sizes; re-run after anything that changes CAT_KB.
sort_by_size() {
    local order i j=0
    order=$(for i in $(cat_indices); do printf '%s\t%s\n' "${CAT_KB[$i]}" "$i"; done \
            | sort -rn -k1,1 -s | cut -f2)
    local ICON=() NAME=() DESC=() METHOD=() DEFAULT=() PATHS=() KB=() SEL=() PMETHOD=() SUMMARY=()
    for i in $order; do
        ICON[$j]="${CAT_ICON[$i]}";       NAME[$j]="${CAT_NAME[$i]}"
        DESC[$j]="${CAT_DESC[$i]}";       METHOD[$j]="${CAT_METHOD[$i]}"
        DEFAULT[$j]="${CAT_DEFAULT[$i]}"; PATHS[$j]="${CAT_PATHS[$i]}"
        KB[$j]="${CAT_KB[$i]}";           SEL[$j]="${CAT_SEL[$i]}"
        PMETHOD[$j]="${CAT_PMETHOD[$i]}"; SUMMARY[$j]="${CAT_SUMMARY[$i]}"
        j=$((j + 1))
    done
    for i in $(cat_indices); do
        CAT_ICON[$i]="${ICON[$i]}";       CAT_NAME[$i]="${NAME[$i]}"
        CAT_DESC[$i]="${DESC[$i]}";       CAT_METHOD[$i]="${METHOD[$i]}"
        CAT_DEFAULT[$i]="${DEFAULT[$i]}"; CAT_PATHS[$i]="${PATHS[$i]}"
        CAT_KB[$i]="${KB[$i]}";           CAT_SEL[$i]="${SEL[$i]}"
        CAT_PMETHOD[$i]="${PMETHOD[$i]}"; CAT_SUMMARY[$i]="${SUMMARY[$i]}"
    done
}

spinner_scan() {
    local pid=$1
    local msg="${2:-Scanning your Mac...}"
    local spin='|/-\' i=0
    printf '%s' " ${CYAN}${msg}${NC} "
    while kill -0 "$pid" 2>/dev/null; do
        i=$(( (i + 1) % 4 ))
        printf '[%s]' "${spin:$i:1}"
        sleep 0.1
        printf '\b\b\b'
    done
    printf '   \b\b\b\n'
}

# ---------------------------------------------------------------------------
# Selection summaries
# ---------------------------------------------------------------------------
selected_count() { local i c=0; for i in $(cat_indices); do [ "${CAT_SEL[$i]}" = "1" ] && c=$((c + 1)); done; echo "$c"; }
selected_kb()    { local i t=0; for i in $(cat_indices); do [ "${CAT_SEL[$i]}" = "1" ] && t=$((t + ${CAT_KB[$i]})); done; echo "$t"; }

# ---------------------------------------------------------------------------
# TUI
# ---------------------------------------------------------------------------
CURSOR=0
SCROLL=0
# Set by the SIGWINCH trap (terminal resized), consumed by the interactive loop
# to trigger a redraw at the new size. Cleared just before each blocking read.
NEED_REDRAW=0
# Terminal size. Primary source is `stty size` (reads the tty on fd 0, which the
# interactive loop keeps connected) — unlike `tput lines/cols`, which query the
# *output* fd and therefore return the static terminfo default (usually 24x80)
# when called inside a $(...) command substitution, where fd 1 is a pipe. tput,
# $LINES/$COLUMNS, then a constant serve as fallbacks.
term_rows() {
    local n; n=$(stty size 2>/dev/null | awk '{print $1}')
    case "$n" in ''|0|*[!0-9]*) n=$(tput lines 2>/dev/null) ;; esac
    case "$n" in ''|0|*[!0-9]*) n=${LINES:-} ;; esac
    case "$n" in ''|0|*[!0-9]*) n=24 ;; esac
    printf '%s' "$n"
}
term_cols() {
    local n; n=$(stty size 2>/dev/null | awk '{print $2}')
    case "$n" in ''|0|*[!0-9]*) n=$(tput cols 2>/dev/null) ;; esac
    case "$n" in ''|0|*[!0-9]*) n=${COLUMNS:-} ;; esac
    case "$n" in ''|0|*[!0-9]*) n=80 ;; esac
    printf '%s' "$n"
}

# clip_plain <text> <max> — clip a plain (uncolored) string to <max> display
# columns, appending an ellipsis when it was shortened. Used for the unbounded
# fields (row summary, item description) so a long value can never wrap onto a
# second physical line and throw off the fixed-height layout.
clip_plain() {
    local s="$1" max="$2"
    [ "$max" -lt 1 ] && { printf ''; return; }
    if [ "${#s}" -le "$max" ]; then printf '%s' "$s"
    else printf '%s…' "${s:0:$((max - 1))}"; fi
}

render_menu() {
    local rows cols; rows=$(term_rows); cols=$(term_cols)
    case "$rows" in ''|*[!0-9]*) rows=24 ;; esac
    case "$cols" in ''|*[!0-9]*) cols=80 ;; esac
    # Fixed chrome is exactly 6 lines (title, status, keys, ↑-scroll, ↓-scroll,
    # description); every other terminal row is given to the item list. Item rows
    # and the description are clipped to the terminal width below, so each stays a
    # single physical line and this count is exact — the list fills the screen.
    local viewport=$((rows - 6))
    [ "$viewport" -lt 3 ] && viewport=3
    if [ "$CURSOR" -lt "$SCROLL" ]; then SCROLL=$CURSOR; fi
    if [ "$CURSOR" -ge $((SCROLL + viewport)) ]; then SCROLL=$((CURSOR - viewport + 1)); fi
    [ "$SCROLL" -lt 0 ] && SCROLL=0

    local sel_c sel_kb; sel_c=$(selected_count); sel_kb=$(selected_kb)
    local buf="" tag=""
    [ "$DRY_RUN" -eq 1 ] && tag="   ${YELLOW}DRY RUN — nothing will be deleted${NC}"
    buf+="${BLUE}🧹 ${BOLD}clean-my-mac${NC}${BLUE} — reclaim your disk${NC}${tag}\033[K\n"
    buf+="Selected ${BOLD}${sel_c}${NC}/${N}   Reclaimable ${BOLD}${GREEN}$(human_kb "$sel_kb")${NC}\033[K\n"
    if [ "$DRY_RUN" -eq 1 ]; then
        buf+="[${DIM}↑↓${NC}] move · [${BOLD}Space${NC}] toggle · [${BOLD}a${NC}]/[${BOLD}s${NC}]/[${BOLD}n${NC}] all/safe/none · [${BOLD}Enter${NC}] paths · [${BOLD}q${NC}] quit\033[K\n"
    else
        buf+="[${DIM}↑↓${NC}] move · [${BOLD}Space${NC}] toggle · [${BOLD}a${NC}]/[${BOLD}s${NC}]/[${BOLD}n${NC}] all/safe/none · [${BOLD}Enter${NC}] details · [${BOLD}c${NC}] clean · [${BOLD}q${NC}] quit\033[K\n"
    fi

    local i last=$((SCROLL + viewport - 1)); [ "$last" -ge "$N" ] && last=$((N - 1))
    if [ "$SCROLL" -gt 0 ]; then buf+="   ${DIM}↑ ${SCROLL} more above${NC}\033[K\n"; else buf+="\033[K\n"; fi
    for i in $(seq "$SCROLL" "$last"); do
        local box size nm line
        if [ "${CAT_SEL[$i]}" = "1" ]; then box="[${GREEN}✓${NC}]"; else box="[ ]"; fi
        size=$(human_kb "${CAT_KB[$i]}")
        # Clip the name to the name column so a long name can't push the line wide.
        nm=$(clip_plain "${CAT_NAME[$i]}" 36)
        line=$(printf '%s %s %-36s %10s' "$box" "${CAT_ICON[$i]}" "$nm" "$size")
        line="${line//%/%%}"   # buf is a printf FORMAT string — neutralize data %
        # Per-project rows show a dim "what's inside" summary that fills the rest
        # of the line: the fixed columns above (box, icon, name, size + gaps)
        # occupy 60 display cols, so the summary gets the remaining width and
        # reaches — but never crosses — the right edge, so it never wraps.
        local suf=""
        if [ -n "${CAT_SUMMARY[$i]}" ]; then
            local s; s=$(clip_plain "${CAT_SUMMARY[$i]}" $((cols - 60)))
            [ -n "$s" ] && suf="  ${DIM}${s//%/%%}${NC}"
        fi
        if [ "$i" -eq "$CURSOR" ]; then buf+="${CYAN}❯ ${BOLD}${line}${NC}${suf}\033[K\n"; else buf+="  ${line}${suf}\033[K\n"; fi
    done
    if [ "$last" -lt $((N - 1)) ]; then buf+="   ${DIM}↓ $((N - 1 - last)) more below${NC}\033[K\n"; else buf+="\033[K\n"; fi

    local desc; desc=$(clip_plain "${CAT_DESC[$CURSOR]}" $((cols - 1)))
    buf+="${DIM}${desc//%/%%}${NC}\033[K\n"
    printf '\033[H\033[2J'
    printf "$buf"
}

# wait_any_key — block until a real keypress. On shells whose read returns when
# a trapped SIGWINCH (terminal resize) fires, that wake carries no key; absorb it
# so a resize never dismisses a "press any key" prompt. (On bash 3.2 read simply
# restarts, so this just blocks until a key — same intended effect.) Stops on a
# real key or on stdin EOF.
wait_any_key() {
    while ! IFS= read -r -s -n 1 _ <&3 2>/dev/null; do
        [ "${NEED_REDRAW:-0}" = 1 ] || break
        NEED_REDRAW=0
    done
}

show_details() {
    local i=$CURSOR
    printf '\033[H\033[2J'
    printf '%s\n' "${BLUE}== ${CAT_ICON[$i]} ${CAT_NAME[$i]} ==${NC}"
    printf '%s\n\n' "${DIM}${CAT_DESC[$i]}${NC}"
    local label
    case "${CAT_METHOD[$i]}" in
        trash)      label="${YELLOW}move to Trash (recoverable)${NC}" ;;
        emptytrash) label="${RED}permanently empty the Trash${NC}" ;;
        container)  label="${RED}run 'system prune -af' (images/containers/build cache; volumes kept)${NC}" ;;
        project)    label="${RED}delete build/dep dirs${NC} + ${YELLOW}Trash other git-ignored (recoverable)${NC}" ;;
        *)          label="${RED}delete permanently${NC}" ;;
    esac
    printf 'Action: %s\n' "$label"
    printf 'Total:  %s\n\n' "$(human_kb "${CAT_KB[$i]}")"
    local p n=0
    if [ "${CAT_METHOD[$i]}" = "container" ]; then
        printf '%s\n' "Engines:"
        while IFS= read -r p; do [ -n "$p" ] && printf '  %s\n' "$p"; done <<EOF
${CAT_PATHS[$i]}
EOF
    elif [ "${CAT_METHOD[$i]}" = "project" ]; then
        printf '%s\n' "Items (${RED}delete${NC} = regenerable · ${YELLOW}Trash${NC} = recoverable):"
        local pm act
        while IFS=$'\x1f' read -r pm p; do
            [ -n "$p" ] || continue
            n=$((n + 1))
            [ "$n" -gt 200 ] && { printf '  %s\n' "${DIM}... and more${NC}"; break; }
            case "$pm" in
                trash) act="${YELLOW}Trash ${NC}" ;;
                *)     act="${RED}delete${NC}" ;;
            esac
            printf '  %9s  %b  %s\n' "$(human_kb "$(du_kb "$p")")" "$act" "${p/#$HOME/~}"
        done < <(paste -d $'\x1f' <(printf '%s\n' "${CAT_PMETHOD[$i]}") <(printf '%s\n' "${CAT_PATHS[$i]}"))
    else
        printf '%s\n' "Paths:"
        while IFS= read -r p; do
            [ -n "$p" ] || continue
            n=$((n + 1))
            [ "$n" -gt 200 ] && { printf '  %s\n' "${DIM}... and more${NC}"; break; }
            printf '  %9s  %s\n' "$(human_kb "$(du_kb "$p")")" "${p/#$HOME/~}"
        done <<EOF
${CAT_PATHS[$i]}
EOF
    fi
    printf '\n%s' "${DIM}Press any key to return...${NC}"
    wait_any_key
}

toggle_all() { local t="$1" i; for i in $(cat_indices); do CAT_SEL[$i]="$t"; done; }
select_safe() { local i; for i in $(cat_indices); do CAT_SEL[$i]="${CAT_DEFAULT[$i]}"; done; }

# ---------------------------------------------------------------------------
# Execution
# ---------------------------------------------------------------------------
move_to_trash() {
    local p="$1" trash_dir="$HOME/.Trash" base dest
    mkdir -p "$trash_dir" 2>/dev/null || return 1
    base=$(basename "$p")
    dest="$trash_dir/$base"
    if [ -e "$dest" ]; then
        local ts n=1
        ts=$(date +%Y%m%d-%H%M%S 2>/dev/null || echo now)
        dest="$trash_dir/${base} ${ts}"
        while [ -e "$dest" ]; do dest="$trash_dir/${base} ${ts}-${n}"; n=$((n + 1)); done
    fi
    mv "$p" "$dest" 2>/dev/null || return 1
    [ ! -e "$p" ]
}

delete_path() {
    local method="$1" p="$2"
    # Already gone (e.g. removed by an overlapping category earlier in this run).
    [ -e "$p" ] || return 0
    if ! is_safe_target "$p"; then
        echo "${YELLOW}  skip (unsafe): ${p}${NC}"; return 1
    fi
    case "$method" in
        trash)
            if move_to_trash "$p"; then echo "${GREEN}  trashed:${NC} ${p/#$HOME/~}"
            else echo "${RED}  failed to trash:${NC} ${p/#$HOME/~}"; fi ;;
        rmforce)
            # Read-only trees (Go module cache, Cargo sources): make writable first.
            chmod -R u+w "$p" 2>/dev/null
            rm -rf "$p" 2>/dev/null
            echo "${GREEN}  cleared:${NC} ${p/#$HOME/~}" ;;
        rm)
            rm -rf "$p" 2>/dev/null
            echo "${GREEN}  deleted:${NC} ${p/#$HOME/~}" ;;
    esac
    return 0
}

empty_trash() {
    local trash_dir="$HOME/.Trash" item
    [ -d "$trash_dir" ] || { echo "${DIM}  Trash is already empty.${NC}"; return; }
    for item in "$trash_dir"/* "$trash_dir"/.[!.]*; do
        [ -e "$item" ] || continue
        case "$item" in "$trash_dir"/*) rm -rf "$item" 2>/dev/null ;; esac
    done
    echo "${GREEN}  Trash emptied.${NC}"
}

PLAN_HAS_PERMANENT=0
print_plan() {
    PLAN_HAS_PERMANENT=0
    local i
    echo "${BLUE}================ Cleanup plan ================${NC}"
    for i in $(cat_indices); do
        [ "${CAT_SEL[$i]}" = "1" ] || continue
        local tag
        case "${CAT_METHOD[$i]}" in
            trash)      tag="${YELLOW}→ Trash   ${NC}" ;;
            emptytrash) tag="${RED}EMPTY TRASH${NC}"; PLAN_HAS_PERMANENT=1 ;;
            container)  tag="${RED}PRUNE     ${NC}"; PLAN_HAS_PERMANENT=1 ;;
            project)
                # A project deletes regenerable dirs and/or trashes git-ignored:
                # mark permanent unless every item is Trash-only.
                if printf '%s\n' "${CAT_PMETHOD[$i]}" | grep -qvx 'trash'; then
                    tag="${RED}CLEAN     ${NC}"; PLAN_HAS_PERMANENT=1
                else
                    tag="${YELLOW}→ Trash   ${NC}"
                fi ;;
            *)          tag="${RED}DELETE    ${NC}"; PLAN_HAS_PERMANENT=1 ;;
        esac
        printf '  %s  %s %-40s %10s\n' "$tag" "${CAT_ICON[$i]}" "${CAT_NAME[$i]}" "$(human_kb "${CAT_KB[$i]}")"
    done
    echo "${BLUE}---------------------------------------------${NC}"
    printf '  Total reclaimable: %s%s%s\n' "${BOLD}${GREEN}" "$(human_kb "$(selected_kb)")" "${NC}"
    echo "${BLUE}=============================================${NC}"
}

run_cleanup() {
    printf '\033[?25h'
    [ "$NON_INTERACTIVE" -eq 0 ] && printf '\033[H\033[2J'
    print_plan
    if [ "$(selected_count)" -eq 0 ]; then echo "${YELLOW}Nothing selected.${NC}"; return 1; fi

    # --dry-run stops here, before any confirmation or deletion. Every caller
    # funnels through run_cleanup (the interactive menu and the non-interactive
    # -y path both call it), so the guard belongs here rather than at the call
    # sites: guarding only the menu let `--dry-run --yes` delete for real.
    if [ "$DRY_RUN" -eq 1 ]; then
        echo
        echo "${YELLOW}Dry run — nothing was deleted.${NC}"
        return 1
    fi

    if [ "$NON_INTERACTIVE" -eq 0 ]; then
        echo
        [ "$PLAN_HAS_PERMANENT" -eq 1 ] && echo "${YELLOW}Items marked DELETE / EMPTY TRASH are removed permanently.${NC}"
        printf '%s' "Proceed? (y/N): "
        # Retry on a SIGWINCH-interrupted read so a terminal resize while the
        # prompt is up doesn't count as a (cancelling) empty answer.
        local reply=""
        while ! IFS= read -r reply <&3; do
            [ "${NEED_REDRAW:-0}" = 1 ] || break
            NEED_REDRAW=0
        done
        case "$reply" in y|Y|yes|YES) : ;; *) echo "${BLUE}Cancelled. Nothing was touched.${NC}"; return 1 ;; esac
    fi

    echo
    {
        echo "=================================================="
        echo "clean-my-mac run: $(date)"
        echo "=================================================="
        local i method p
        for i in $(cat_indices); do
            [ "${CAT_SEL[$i]}" = "1" ] || continue
            method="${CAT_METHOD[$i]}"
            echo "${BLUE}▸ ${CAT_NAME[$i]}${NC}"
            if [ "$method" = "emptytrash" ]; then empty_trash; continue; fi
            if [ "$method" = "container" ]; then run_container_prune "${CAT_PATHS[$i]}"; continue; fi
            if [ "$method" = "project" ]; then
                # Per-project categories carry a per-path method (rm vs trash);
                # pair each path with its method (US-joined) and act accordingly.
                local pm
                while IFS=$'\x1f' read -r pm p; do
                    [ -n "$p" ] || continue
                    delete_path "$pm" "$p"
                done < <(paste -d $'\x1f' <(printf '%s\n' "${CAT_PMETHOD[$i]}") <(printf '%s\n' "${CAT_PATHS[$i]}"))
                continue
            fi
            while IFS= read -r p; do
                [ -n "$p" ] || continue
                delete_path "$method" "$p"
            done <<EOF
${CAT_PATHS[$i]}
EOF
        done
        echo "=================================================="
        echo "Finished: $(date)"
        echo "=================================================="
    } 2>&1 | tee -a "$LOG_FILE"

    echo
    echo "${GREEN}${BOLD}Done.${NC} Freed roughly ${BOLD}${GREEN}$(human_kb "$(selected_kb)")${NC}."
    local i
    for i in $(cat_indices); do
        [ "${CAT_SEL[$i]}" = "1" ] || continue
        if [ "${CAT_METHOD[$i]}" = "trash" ] \
           || { [ "${CAT_METHOD[$i]}" = "project" ] && printf '%s\n' "${CAT_PMETHOD[$i]}" | grep -qx 'trash'; }; then
            echo "Items moved to the Trash can be restored from there."
            break
        fi
    done
    echo "Log: ${YELLOW}${LOG_FILE}${NC}"
    return 0
}

# offer_project_scan — interactive prompt (shown when -p was not passed) to also
# scan code repos. Runs scan_projects in the FOREGROUND: it mutates the in-memory
# category arrays, so it must not be a background/subshell job. Re-sizes and
# re-prunes so the newly found projects appear in the menu.
offer_project_scan() {
    printf '\n'
    printf '%b\n' "  ${CYAN}Also scan your code repos for build/dependency junk?${NC}"
    printf '%b'   "  ${DIM}node_modules, dist, build, target, __pycache__, git-ignored — can take a moment.${NC} [Y/n] "
    # Act on the first keypress — no Enter needed. y/Y or Enter means Yes;
    # any other key (n, Esc, ...) means No. A failed read also means No.
    local reply=""
    if ! IFS= read -r -s -n 1 reply <&3 2>/dev/null; then
        printf '\n'
        return 0
    fi
    printf '\n'
    case "$reply" in
        y|Y|"")
            PROJECTS_ENABLED=1
            printf '%b' " ${CYAN}Scanning code repos (this can take a moment)...${NC}"
            scan_projects
            printf '\r\033[K'
            compute_sizes
            prune_zero
            sort_by_size
            ;;
    esac
}

# Test hook: load functions only when sourced with CLEAN_MY_MAC_LIB=1.
if [ "${CLEAN_MY_MAC_LIB:-}" = "1" ]; then
    return 0 2>/dev/null || exit 0
fi

# ---- Resolve & stage pattern files -----------------------------------------
if ! resolve_patterns; then
    exit 1
fi

# ---- Scan ------------------------------------------------------------------
build_installed_set &
spinner_scan $! "Analyzing installed apps & leftover data..."
wait

if [ "$PROJECTS_ENABLED" -eq 1 ]; then
    printf '%s' " ${CYAN}Scanning caches & code repos...${NC} "
else
    printf '%s' " ${CYAN}Scanning caches...${NC} "
fi
build_categories
printf '\r\033[K'

# A load failure must not masquerade as a clean system.
if [ "${PARSED_OK:-0}" -eq 0 ]; then
    echo "${RED}Error: no valid pattern files could be parsed — cannot continue.${NC}" >&2
    echo "${DIM}Check the pattern JSON (see 'clean-my-mac --help' for --patterns).${NC}" >&2
    exit 1
fi

if [ "$N" -gt 0 ]; then
    compute_sizes
    prune_zero
    sort_by_size
fi

# Fast by default: project scanning is off unless -p was given, so offer it here
# (interactive runs only). Accepting scans code repos and folds the results in.
if [ "$NON_INTERACTIVE" -eq 0 ] && [ "$PROJECTS_ENABLED" -eq 0 ]; then
    offer_project_scan
fi

if [ "$N" -eq 0 ]; then
    echo "${GREEN}Nothing to reclaim — everything is already clean.${NC}"
    exit 0
fi

# ---- Non-interactive -------------------------------------------------------
if [ "$ASSUME_YES" -eq 1 ]; then
    select_safe
    run_cleanup
    exit $?
fi

# ---- Interactive menu ------------------------------------------------------
# Redraw on terminal resize. A SIGWINCH sets NEED_REDRAW; the read below polls
# with a 1s timeout because bash 3.2's read does NOT return early when a signal
# fires (it restarts) — so we can't rely on the trap interrupting the read and
# instead wake at least once a second to act on the flag. To avoid flicker the
# menu is re-rendered only when something changed ($dirty): a keypress or resize.
trap 'NEED_REDRAW=1' WINCH
printf '\033[?25l'
dirty=1
while true; do
    [ "$dirty" = 1 ] && { render_menu; dirty=0; }
    SECONDS=0
    if ! IFS= read -r -s -n 1 -t 1 key <&3 2>/dev/null; then
        # No key: a resize, an idle 1s timeout, or EOF. Redraw on a resize.
        if [ "$NEED_REDRAW" = 1 ]; then NEED_REDRAW=0; dirty=1; continue; fi
        # bash 3.2 returns 1 for BOTH a timeout and EOF; tell them apart by the
        # elapsed wall-clock — a full 1s timeout advances $SECONDS, whereas a
        # closed stdin (EOF / Ctrl-D) returns instantly.
        [ "$SECONDS" -lt 1 ] && { echo; exit 0; }
        continue
    fi
    NEED_REDRAW=0
    dirty=1
    action=""
    if [ "$key" = $'\e' ]; then
        next=""; read -r -s -n 2 -t 1 next <&3 2>/dev/null
        case "$next" in '[A'|'OA') action="UP" ;; '[B'|'OB') action="DOWN" ;; '') action="QUIT" ;; esac
    elif [ "$key" = " " ]; then action="TOGGLE"
    # Enter reaches `read -n 1` as the empty line delimiter, never as a literal
    # CR/LF — so an empty $key IS Enter.
    elif [ -z "$key" ]; then action="DETAILS"
    else
        case "$key" in
            k|K) action="UP" ;; j|J) action="DOWN" ;;
            d|D) action="DETAILS" ;; a|A) action="ALL" ;;
            s|S) action="SAFE" ;; n|N) action="NONE" ;;
            c|C) action="CLEAN" ;; q|Q|e|E) action="QUIT" ;;
        esac
    fi
    case "$action" in
        UP)   CURSOR=$((CURSOR - 1)); [ "$CURSOR" -lt 0 ] && CURSOR=$((N - 1)) ;;
        DOWN) CURSOR=$((CURSOR + 1)); [ "$CURSOR" -ge "$N" ] && CURSOR=0 ;;
        TOGGLE) CAT_SEL[$CURSOR]=$((1 - ${CAT_SEL[$CURSOR]})) ;;
        ALL)  toggle_all 1 ;;
        NONE) toggle_all 0 ;;
        SAFE) select_safe ;;
        DETAILS) printf '\033[?25h'; show_details; printf '\033[?25l' ;;
        CLEAN)
            # run_cleanup refuses to delete under --dry-run but still prints the
            # plan, so `c` shows what would be freed instead of doing nothing.
            if run_cleanup; then
                echo; printf '%s' "${DIM}Press any key to return to the menu...${NC}"
                wait_any_key
                printf '%s' " ${CYAN}Rescanning...${NC} "
                build_categories; printf '\r\033[K'
                [ "$N" -eq 0 ] && { printf '\033[?25h'; printf '\033[H\033[2J'; echo "${GREEN}All clean!${NC}"; exit 0; }
                compute_sizes; prune_zero; sort_by_size
                [ "$N" -eq 0 ] && { printf '\033[?25h'; printf '\033[H\033[2J'; echo "${GREEN}All clean!${NC}"; exit 0; }
                CURSOR=0; SCROLL=0
            else
                echo; printf '%s' "${DIM}Press any key to return to the menu...${NC}"
                wait_any_key
            fi
            printf '\033[?25l'
            ;;
        QUIT) printf '\033[?25h'; printf '\033[H\033[2J'; echo "${BLUE}Goodbye!${NC}"; exit 0 ;;
    esac
done
