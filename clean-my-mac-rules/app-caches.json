    },
    {
      "icon": "🧬",
      "name": "Chrome on-device AI models",
      "method": "rm",
      "default": false,
      "desc": "Chrome's downloaded on-device AI / optimization-guide models — regenerable, but several GB to re-download if you use those features.",
      "paths": [
        "~/Library/Application Support/Google/Chrome/OptGuideOnDeviceModel",
        "~/Library/Application Support/Google/Chrome/OptGuideOnDeviceClassifierModel",
        "~/Library/Application Support/Google/Chrome/optimization_guide_model_store"
      ]
    },
    {
      "icon": "📡",
      "name": "Crash-reporter & telemetry SDK caches",
      "method": "rm",
      "default": true,
      "desc": "Queued crash/analytics payloads & updater caches dropped by embedded SDKs (Sentry, Crashlytics, Sparkle, Keystone, Segment, ...) — regenerated as needed.",
      "paths": [
        "~/Library/Caches/SentryCrash",
        "~/Library/Caches/KSCrash",
        "~/Library/Caches/com.crashlytics",
        "~/Library/Caches/com.crashlytics.data",
        "~/Library/Caches/org.sparkle-project.Sparkle",
        "~/Library/Caches/com.google.SoftwareUpdate",
        "~/Library/Caches/com.google.Keystone",
        "~/Library/Caches/com.segment.analytics",
        "~/Library/Caches/Rollbar",
        "~/Library/Caches/Amplitude",
        "~/Library/Caches/Realm",
        "~/Library/Caches/Parse",
        "~/Library/Caches/CCTClearcutLogger"
      ]
    },
    {
      "icon": "📥",
      "name": "App updater staging caches",
      "method": "rm",
      "default": true,
      "desc": "Downloaded update payloads left behind by Squirrel/Sparkle & Google's updater after installing — re-fetched only if an update is pending.",
      "paths": [
        "~/Library/Caches/*.ShipIt",
        "~/Library/Application Support/Google/GoogleUpdater/*.old",
        "~/Library/Application Support/Caches/*.ShipIt"
      ]
    },
    {
      "icon": "📦",
      "name": "Sandboxed app caches",
      "method": "rm",
      "default": false,
      "desc": "Caches inside sandboxed (App Store) apps' containers — rebuilt as needed.",
      "paths": [
        "~/Library/Containers/*/Data/Library/Caches"
      ]
    },
    {
      "icon": "📋",
      "name": "Crash & diagnostic logs",
      "method": "rm",
      "default": false,
      "desc": "Old crash reports & simulator diagnostic logs — regenerated as needed.",
      "paths": [
        "~/Library/Logs/DiagnosticReports",
        "~/Library/Logs/CoreSimulator"
      ]
    },
    {
      "icon": "🚮",
      "name": "Empty the Trash",
      "method": "emptytrash",
      "default": false,
      "desc": "Permanently erase everything currently in the Trash — cannot be undone.",
      "paths": [
        "~/.Trash"
      ]
    }
  ]
}
