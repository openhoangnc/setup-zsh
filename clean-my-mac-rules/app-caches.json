{
  "title": "Browser & application caches",
  "_comment": "Application-level caches. The Electron/Chromium entry uses * globs to match the Cache/GPUCache/etc. folders that Electron apps (VS Code, Claude, Slack, Discord, ...) create under Application Support. These hold only re-fetchable data. Chromium *browsers* keep their per-profile caches one level deeper (Google/Chrome/<profile>/...), so they need their own entry — the depth-2 glob above does not reach them. method: emptytrash empties ~/.Trash (irreversible). Note: only 'Service Worker/CacheStorage' is listed, never 'Service Worker/ScriptCache' — the latter holds MV3 extension bytecode and removing it breaks extension service workers mid-session.",
  "categories": [
    {
      "icon": "⚡",
      "name": "Electron / Chromium app caches",
      "method": "rm",
      "default": true,
      "desc": "Disk/GPU/code caches inside Electron apps (VS Code, Claude, Slack, ...) — rebuilt on launch.",
      "paths": [
        "~/Library/Application Support/*/Cache",
        "~/Library/Application Support/*/Code Cache",
        "~/Library/Application Support/*/GPUCache",
        "~/Library/Application Support/*/CachedData",
        "~/Library/Application Support/*/CachedExtensionVSIXs",
        "~/Library/Application Support/*/CachedProfilesData",
        "~/Library/Application Support/*/DawnCache",
        "~/Library/Application Support/*/DawnGraphiteCache",
        "~/Library/Application Support/*/DawnWebGPUCache",
        "~/Library/Application Support/*/GrShaderCache",
        "~/Library/Application Support/*/GraphiteDawnCache",
        "~/Library/Application Support/*/ShaderCache",
        "~/Library/Application Support/*/Service Worker/CacheStorage",
        "~/Library/Application Support/*/WebStorage/*/CacheStorage",
        "~/Library/Application Support/*/Crashpad/completed",
        "~/Library/Application Support/*/Partitions/*/Cache",
        "~/Library/Application Support/*/component_crx_cache",
        "~/Library/Application Support/*/extensions_crx_cache",
        "~/Library/Application Support/*/logs"
      ]
    },
    {
      "icon": "🌐",
      "name": "Browser caches",
      "method": "rm",
      "default": true,
      "desc": "HTTP/disk caches for Chrome, Brave, Edge, Vivaldi, Arc, Firefox — safe to clear.",
      "paths": [
        "~/Library/Caches/Google",
        "~/Library/Caches/com.google.Chrome",
        "~/Library/Caches/Chromium",
        "~/Library/Caches/BraveSoftware",
        "~/Library/Caches/com.microsoft.edgemac",
        "~/Library/Caches/Microsoft Edge",
        "~/Library/Caches/company.thebrowser.Browser",
        "~/Library/Caches/company.thebrowser.dia",
        "~/Library/Caches/Vivaldi",
        "~/Library/Caches/com.vivaldi.Vivaldi",
        "~/Library/Caches/com.operasoftware.Opera",
        "~/Library/Caches/Firefox",
        "~/Library/Caches/Mozilla",
        "~/Library/Caches/com.apple.Safari",
        "~/Library/Caches/com.kagi.kagimacOS",
        "~/Library/Caches/zen"
      ]
    },
    {
